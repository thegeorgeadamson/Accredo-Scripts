  <![CDATA['Imports "API\CheckPreDefined.pfs"

Dim TransferListForm as Object

Public Property Let SetOtherForm(Value as Object)
  TransferListForm = Value
End Property

Dim ICBar as Object
ICBar = opentable("ICBAR")
ICBar.IndexName = "Barcode"

WarningColor = 240
DefaultColor = -16777201
SelLn = 1

Dim NTable as Object
NTable = opencustomtable("TransferNarratives")
NTable.IndexName = "Document"

StaffScan = True
ForceClose = False
DocID = 0
OpenExisting = False
InsertMode = False
LoadMode = False
EditMode = False
ReceiptMode = False
Dim Contin as Boolean

SourceLocation = False
DestinationLocation = False

tblTransfers_Clone = tblTransfers.Clone

Dim ICProdData as object
ICProdData = createobject("Accredo.ICProductData")
ICProdData.Indexname = "Product"

Dim ICPROD as OBJECT
ICPROD = Opentable("ICPROD")
ICPROD.indexname = "Product"

Dim ICLOCN as OBJECT
ICLOCN = Opentable("ICLOCN")
ICLOCN.indexname = "ActiveLocation"

Dim ICTFER as Object
ICTFER = createobject("Accredo.ICTransferData")
ICTFER.IndexName = "Document"

Sub Status
  IF Not StaffScan then
    eStatus.Text = "Scan Staff Reference"
  Else
    eStatus.Text = "Scan Product"
  End IF
End Sub

Sub btnInitSwitch_Click

  preSource = pnlInitSource.Text
  pnlInitSource.Text = pnlInitDest.Text
  pnlInitDest.Text = preSource

End Sub

Sub Reset
  OpenExisting = False
  SourceLocation = false
  DestinationLocation = False
  StaffScan = True
  eDocID.Value = 0
  tblTransfers_Clone.Empty
  tblTransfers.Refresh
  eSourceLocation.Text = ""
  eDestinationLocation.Text = ""
  btnComplete.Enabled = True
  eSourceLocation.Enabled = SourceLocation
  eDestinationLocation.Enabled = DestinationLocation
  eMode.Text = ""
  Status
End Sub


'Sub btnAssignBarcode_Click
'  eBarcode.SetFocus
'  AssignBarcodeForm = CreateCustomForm("BinLocation_Quick_Input_EAN128.pfd")
'End Sub

Sub HighlightLine(Sender as Object, Field as Object, Row as Number, Highlight as Boolean, CellFont as Object, ByRef BackColor as Number)

   IF tblTransfers.productcode = eProductCode.text and (Row = SelLn - 1) Then
     BackColor = 65535
     CellFont.Bold = False
'     IF User.LoginUserName = "ACCREDO" Then msgbox(Row & "|" & tblTransfers.LineNo - 1)
   End If
End Sub

Sub GridTimer_Tick
  gridEditGrid1.OnCalcCellColors = GetRef("HighLightLine")
  tblTransfers.Refresh
  GridTimer.Enabled = False
End Sub

Sub DoNothing
  ';;NOT A WHOLE LOT HAPPENING HERE...
End Sub



Sub tblTransfers_AfterScroll
  SelLN = tblTransfers.LineNo
  IF NOT InsertMode Then
    IF tblTransfers.ProductCode <> "" Then 'Exit Sub
      GridTimer.Enabled = False
      gridEditGrid1.OnCalcCellColors = GetRef("DoNothing")
      GridTimer.Enabled = True
    End IF
  Else
    gridEditGrid1.OnCalcCellColors = GetRef("DoNothing")
  End IF

End Sub



Sub Close
  Self.Close
  Try
    TransferListForm.RunRefresh.checked = not TransferListForm.RunRefresh.Checked
    TransferListForm.eBarcode.SetFocus
  Catch

  End Try
End Sub

Sub ConfirmClose
  IF ForceClose = False then
    If Not inputquery("Confirm Close") then
      abort("",True)
    End IF
  End IF
  Try
    TransferListForm.RunRefresh.checked = not TransferListForm.RunRefresh.Checked
  Catch
  End Try

End SUb

Sub ProductDetails
  IF ICPROD.FIndexact(tblTransfers.ProductCode) then
    eProductCode.Text = ICPROD.ProductCode
    eProductName.Text = ICPROD.Description
    if ApplicationSetting( "IC\ValuationBasis") = "L" Then
      eCostPrice.Text = formatNumber(ICPROD.LatestCost,"Amount")
    Elseif ApplicationSetting( "IC\ValuationBasis") = "A" Then
      eCostPrice.Value = ICPROD.AverageCost
    Elseif ApplicationSetting( "IC\ValuationBasis") = "S" Then
      eCostPrice.Value = ICPROD.StandardCost
    End IF
  End IF
  ePicked.Value = tblTransfers.Quantity
End Sub

Sub ProductCode_OnEnter

  If tblTransfers.ProductCode <> "" Then
    ProductDetails
    tblTransfers.Refresh
  End IF

End Sub

Sub pnlInitBtnOK_Click

  IF pnlInitSource.Text = "" then
    pnlInitSource.ShowErrorHint("Please Enter Source Location")
    Abort("",True)
  ElseIF pnlInitDest.Text = "" then
    pnlInitDest.ShowErrorHint("Please Enter Destination Location")
    Abort("",True)
  End IF

  IF ICLOCN.Findexact(False,pnlInitSource.Text) then
    If ICLOCN.LocationCode <> pnlInitDest.Text Then
      eSourceLocation.Text = ICLOCN.LocationCode
      SourceLocation = True
      eSourceLocation.Enabled = SourceLocation
    Else
      PnlInitSource.ShowErrorHint("Source Location Cannot be Same as Destination")
      Abort("",True)
    End IF
  Else
    PnlInitSource.ShowErrorHint("Location Not Found")
    Abort("",True)
  End IF

  IF ICLOCN.Findexact(False,pnlInitDest.Text) then
    If ICLOCN.LocationCode <> pnlInitSource.Text Then
      eDestinationLocation.Text = ICLOCN.LocationCode
      DestinationLocation = True
      eDestinationLocation.Enabled = DestinationLocation
    Else
      PnlInitDest.ShowErrorHint("Destination Location Cannot be Same as Source")
      Abort("",True)
    End IF
  Else
    PnlInitDest.ShowErrorHint("Location Not Found")
    Abort("",True)
  End IF

  pnlInit.Visible = False
  eBarcode.SetFocus
End Sub

Sub OnLoad

ProdQtyRO = True
AutoPopulateQty = False

  eTransferDate.Value = Systemdate

  IF ScriptArgs.Count > 1 then
    DocID = ScriptArgs[1]

    IF ScriptArgs.Count = 3 then
      IF ScriptArgs[2] = "EDIT" then
        EditMode = True
        LoadMode = False
        ReceiptMode = False
        eMode.Text = "EDIT MODE"
        tblTransfers_Clone.Fields.item("Adjustment").Visible = False
        btnComplete.Enabled = False
        btnSave.Enabled = True
        btnPrint.Enabled = True
        ProdQtyRO = False
        btnAddItem.Enabled = True
      End IF
      IF ScriptArgs[2] = "LOADPALLET" THEN
        eMode.Text = "LOAD PALLET MODE"
        LoadMode = True
        EditMode = False
        ReceiptMode = False
        tblTransfers.Fields.item("Adjustment").Visible = False
        btnComplete.Caption = "Dispatch"
        btnSave.Enabled = False
        btnPrint.Enabled = False
        btnAddItem.Enabled = False
      End If
      IF ScriptArgs[2] = "RECEIPT" then
        ReceiptMode = True
        EditMode = False
        LoadMode = False
        eMode.Text = "RECEIPT MODE"
        btnSave.Enabled = False
        btnPrint.Enabled = False
        btnAddItem.Enabled = False
      End IF
    End IF

    IF ICTFER.FindExact(DocID) then
      OpenExisting = True
      tblTransfers.AllowInsertDelete = True
      IF NOT EditMode then
        tblTransfers.Active = False
        tblTransfers.AddField("QuantityExpected","Quantity")
        tblTransfers.Active = True
      End IF
      eSourceLocation.Text = ICTFER.SourceLocationCode
      eDestinationLocation.Text = ICTFER.DestinationLocationCode
      SourceLocation = True
      DestinationLocation = True
      eReference.Text = ICTFER.Reference
      Status

      IF left(eReference.Text,17) = "REJECTED TRANSFER" AND ReceiptMode then
        AutoPopulateQty = True
'        eStatus.ShowStatusHint("Click Complete to Acknowledge, products do not require scanning!")
      End IF

      LN = ICTFER.Line

      Ln.First

      tblTransfers.Refresh
      tblTransfers_Clone = tblTransfers.Clone
      tblTransfers_Clone.IndexName = "Product"

      Do Until LN.EOF


        tblTransfers_Clone.Append
        tblTransfers_Clone.ProductCode = LN.ProductCode
        tblTransfers_Clone.Description = LN.Description
        IF EditMode then
          tblTransfers_Clone.Quantity = LN.QuantityDispatched
        Else
          tblTransfers_Clone.QuantityExpected = LN.Quantity
          IF AutoPopulateQty then tblTransfers_Clone.Quantity = LN.Quantity
        End IF

        tblTransfers_Clone.Unit = LN.Unit

        IF tblTransfers_Clone.Fields.item("Adjustment").Visible = True AND ReceiptMode Then
          tblTransfers_Clone.Adjustment = tblTransfers_Clone.QuantityExpected
        End IF
        IF ICProdData.FindExact(LN.ProductCode) then
          ICProdData.Barcodes.First
          IF ICProdData.Barcodes.Barcode <> "" then
            tblTransfers_Clone.Barcode = ICProdData.Barcodes.Barcode
          End IF
        End IF
        tblTransfers_Clone.LineID = LN.LineID
        tblTransfers_Clone.LineNo = LN.LineNo
        tblTransfers_Clone.Save
        tblTransfers_Clone.Refresh
       LN.Next
      Loop
      tblTransfers_Clone.First
      ProductDetails
    End IF
  Else
    'Insert Mode
    InsertMode = True
    SourceLocation = False
    DestinationLocation = False
    Dest = ""
    IF User.DefaultLocationCode <> "" then
      pnlInitDest.Text = User.DefaultLocationCode
      ICL = opentable("ICLOCN")
      ICL.IndexName = "Location"
      ICL.First
      Do Until ICL.EOF
        IF ICL.LocationCode <> pnlInitDest.Text then
          Source = ICL.LocationCode
          Exit Do
        End IF
       ICL.Next
      Loop
      pnlInitSource.Text = Source
    Else
      msgbox("Please set User's Default Location Code")
    End IF
    pnlInit.Top = 168
    pnlInit.Left = 307
    pnlInit.Visible = True
    pnlInitSource.SetFocus
    Reset
    Status
    eMode.Text = "INSERT MODE"
    btnComplete.Enabled = False
    ProdQtyRO = False
  End IF
  tblTempClone.Empty

  ';;COPY EVERYTHING FROM TRANSFERS TO TEMP CLONE TABLE
  tblTransfers_Clone.First
  Do Until tblTransfers_Clone.EOF
    tblTempClone.Insert
    copyfieldsbyname(tblTransfers_clone,tblTempClone)
    tblTempClone.Save
   tblTransfers_Clone.Next
  Loop


';;COPY EVERYTHING FROM NARRATIVE TABLE FOR DOCUMENTID TO TEMP CLONE TABLE
  IF ICTFER.FindExact(DocID) then
    NTable.setrange(DocID)
    NTable.First
    Do Until NTable.EOF
      tblTempClone.Insert
      CopyFieldsbyName(NTable,tblTempClone)
      tblTempCLone.Save
     NTable.Next
    Loop
    NTable.CancelRange
  End IF

  ';;APPLY INDEX TO TEMP CLONE TABLE TO SORT ITEMS BY LINE NO
  tblTempClone.IndexName = "LineNo"

  ';;COPY EVERYTHING FROM TEMP CLONE TABLE BACK TO TRANSFERS TABLE
  tblTransfers_Clone.Empty
  tblTempClone.First
  Do Until tblTempClone.EOF
    tblTransfers_Clone.Append
    copyfieldsbyname(tblTempClone,tblTransfers_Clone)
    tblTransfers_Clone.Save
   tblTempClone.Next
  Loop

  tblTransfers_Clone.Fields.Item("ProductCode").Readonly = ProdQtyRO
  tblTransfers_Clone.Fields.Item("Quantity").Readonly = ProdQtyRO
  IIF(ReceiptMode,tblTransfers_Clone.Fields.Item("Unit").Readonly = ProdQtyRO,tblTransfers_Clone.Fields.Item("Unit").Readonly = False)
  tblTransfers.Fields.Item("ProductCode").Readonly = ProdQtyRO
  tblTransfers.Fields.Item("Quantity").Readonly = ProdQtyRO
  IIF(ReceiptMode,tblTransfers.Fields.Item("Unit").Readonly = ProdQtyRO,tblTransfers.Fields.Item("Unit").Readonly = False)


  tblTransfers.Refresh


End Sub

Sub Prev_Date
  eTransferDate.Value = eTransferDate.Value - 1
  eBarcode.SetFocus
End Sub

Sub Next_Date
  eTransferDate.Value = eTransferDate.Value + 1
  eBarcode.SetFocus
End Sub

Sub SelectCurrentLine

  tblTransfers.StopFormUpdates
  tblTransfers.First
  Do Until tblTransfers.Eof
    IF tblTransfers.ProductCode = eProductCode.Text Then
      Exit Do
    End IF
   tblTransfers.Next
  Loop
  tblTransfers.StartFormUpdates

End Sub

Sub ProductScanCheck

  tblTransfers_Clone.Fields.Item("ProductCode").Readonly = False
  tblTransfers_Clone.Fields.Item("Quantity").Readonly = False
  tblTransfers_Clone.Fields.Item("Unit").Readonly = False

'  CheckPreDefined(eBarcode.Text,tblEAN128)
  Qty = 1
  CPD_ProdCode = ""
  IF ICBar.FindExact(eBarcode.Text) Then
    CPD_ProdCode = ICBar.ProductCode
  End IF
  IF CPD_ProdCode = "" Then CPD_ProdCode = eBarcode.Text



'  tblTransfers.indexname = "Product"
  IF CPD_ProdCode <> "" then
    IF ICProd.FindExact(CPD_ProdCode) then
      IF ICPROD.NonDiminishing <> True then
        IF Not ICPROD.Inactive then
            tblTransfers_Clone.IndexName = "Product"
          IF tblTransfers_Clone.Findexact(ICProd.ProductCode) then
            tblTransfers_Clone.Edit
            tblTransfers_Clone.Quantity= (tblTransfers_Clone.Quantity + Qty)
            IF ReceiptMode then
              tblTransfers_Clone.Adjustment = tblTransfers_Clone.QuantityExpected - tblTransfers_Clone.Quantity
            End IF
            tblTransfers_Clone.Save

            ProductDetails
          Else
'            IF NOT EditMode then
'              IF OpenExisting = True then
'                IF NOT InputQuery("Product " & ICProd.ProductCode & " (" & ICProd.Description & ") was NOT found on the transfer!" & chr(13) & _
'                "Would you like to add this product to the transfer or cancel scan?" & chr(13) & _
'                chr(13) & _
'                "A new transfer will be created and dispatched for this new product. The supplier will need to review and complete the new Transfer") then
'                  Exit Sub
'                End IF
'              End IF
'            End IF

            IF NOT EditMode then
              IF OpenExisting = True then
                self.Color = WarningColor
                APA = createcustomform("Barcoding\AddProductAlert")

                APA.lblAlert.Caption = "Product " & ICProd.ProductCode & " (" & ICProd.Description & ") was NOT found on the transfer!" & chr(13) & _
                  "Would you like to add this product to the transfer or cancel scan?" & chr(13) & _
                  chr(13) & _
                  "A new transfer will be created and dispatched for this new product. The supplier will need to review " & CHR(13) & _
                  "and complete the new Transfer"
                APA.ShowModal

                self.Color = DefaultColor
                IF APA.ModalResult = 2 then Exit Sub
              End IF
            End IF

            tblTransfers_Clone.AllowInsertDelete = True
            tblTransfers_Clone.Append
            tblTransfers_Clone.ProductCode = ICProd.ProductCode
            tblTransfers_Clone.Description = ICPROD.Description
            Try
              tblTransfers_Clone.Unit = ICProd.Unit
            Catch
            End Try
            tblTransfers_Clone.Quantity = (tblTransfers_Clone.Quantity + Qty)
            tblTransfers_Clone.Save
            'tblTransfers.AllowInsertDelete = False

            ProductDetails
          End IF
          tblTransfers.refresh

        Else
          eBarcode.Showerrorhint("Product is Inactive")
        End IF

        eProductCode.Text = CPD_ProdCode
        eProductName.Text = ICPROD.Description

      Else
        eBarcode.Showerrorhint("Product is No Diminishing")
      End IF
    End IF
  Else
    eBarcode.Showerrorhint("An unknown error has occurred")
  End If


  eBarcode.SetFocus
  IF NOT InsertMode then
    tblTransfers_Clone.Fields.Item("ProductCode").Readonly = True
    tblTransfers_Clone.Fields.Item("Quantity").Readonly = True
    tblTransfers_Clone.Fields.Item("Unit").Readonly = True
  End IF

  IF tblTransfers.ProductCode <> eProductCode.Text Then SelectCurrentLine()
End Sub

Sub AddProduct

  IF ICProd.FindExact(eProduct.Text) AND (InsertMode OR EditMode) then
    tblTransfers.ProductCode = ICProd.ProductCode
    tblTransfers.Description = ICProd.Description
    Try
      tblTransfers.Unit = ICProd.Unit
    Catch e
      msgbox("Error: " & e.message)
    End Try
  End IF

  Try
    'gridEditGrid1.ActiveColumn = gridEditGrid1.ActiveColumn + 2

  Catch

  End Try


End Sub

Sub Move_Next
  tblTransfers.Next
  ProductDetails
 eBarcode.SetFocus


End Sub
Sub Move_Prev
  tblTransfers.Prev
  ProductDetails
 eBarcode.SetFocus
End Sub

