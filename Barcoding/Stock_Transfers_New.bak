Sub CheckUOM

  Contin = True
  tblTransfers.First
  Do until tblTransfers.EOF
    IF tblTransfers.Unit <> "KG" AND tblTransfers.Quantity <> round(tblTransfers.Quantity) then
      Contin = False
      Exit Do
    END IF
    tblTransfers.Next
  Loop


End Sub

Sub Save(PrintTransfer as Boolean)

  CheckUOM
  IF Contin = False then
    'Msgbox("Quantity (" & tblTransfers.Z_QuantityUOM & ") on Product " & tblTransfers.ProductCode & " is not a round number, please correct before proceeding")
    tblTransfers.ShowFieldErrorHint("Quantity (" & tblTransfers.Quantity & ") on Product " & tblTransfers.ProductCode & " is not a round number, please correct before proceeding","Quantity")
    Exit Sub
  END IF

  tblTransfers.First

  IF LoadMode then
    IF InputQuery("Are you sure you want save?") Then
      ';;CONTINUE
    Else
      btnSave.ShowErrorHint("Save Aborted")
      Abort("",True)
    End IF
  End IF
  Dim TransfData as Object
  TransfData = CreateObject("Accredo.ICTransferData")
  IF DocID = 0 then
    TransfData.InsertTransfer
  Else
    IF TransfData.FindExact(DocID) then
      TransfData.Edit
    End IF
  End IF
  TransfData.DocumentDate = eTransferDate.value
  TransfData.ReceiptDate = eTransferDate.value
  TransfData.PeriodID = PeriodforDate(TransfData.DocumentDate)
  TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
  TransfData.SourceLocationCode = eSourceLocation.Text
  TransfData.DestinationLocationCode = eDestinationLocation.Text
  TransfData.TransitLocationCode = "TRANSIT"
  TransfData.Reference = eReference.Text

  IF InsertMode OR EditMode then
    TransfData.Line.Empty
    tblTransfers_Clone.First

    Do until tblTransfers_Clone.Eof
      IF tblTransfers_Clone.ProductCode <> "" then
        TransfData.Line.Append
        TransfData.Line.ProductCode = tblTransfers_Clone.ProductCode
        IF NOT EditMode then
          IF tblTransfers_Clone.Quantity = 0 and tblTransfers_Clone.ProductCode <> "" then
            Try
              TransfData.Line.Quantity = tblTransfers_Clone.QuantityExpected
            Catch e
              tblTransfers_Clone.ShowErrorHint(e.message)
            End Try
          Else
            'TransfData.Line.QuantityDispatched = tblTransfers_Clone.Z_QuantityUOM
            TransfData.Line.Dispatch = tblTransfers_Clone.Quantity
            'TransfData.Line.Unit = tblTransfers_Clone.Unit
          End IF
        Else
          TransfData.Line.QuantityDispatched = tblTransfers_Clone.Quantity
          TransfData.Line.Quantity = tblTransfers_Clone.Quantity
          TransfData.Line.Unit = tblTransfers_Clone.Unit
        End IF
        TransfData.Line.Save
      End IF
     tblTransfers_Clone.Next

    Loop
  End IF
  TransfData.Save

  ';;REMOVE ANY PREVIOUS NARRATIVES FOR DOCUMENT

    NTable.SetRange(TransfData.DocumentID)
    NTable.First
    Do Until NTable.EOF
      NTable.Delete
    Loop
    NTable.CancelRange

  ';;ADD NARRATIVES BACK IN AGAIN

  tblTransfers.First
  CountProd = 0
  CountNar = 0
  Do Until tblTransfers.EOF
    IF tblTransfers.ProductCode <> "" then
      CountProd = CountProd + 1
    Else
      NTable.Insert
      NTable.DocumentID = TransfData.DocumentID
      NTable.Description = tblTransfers.Description
      NTable.LineNo = CountProd + 0.01
      NTable.Save
    End IF
   tblTransfers.Next
  Loop





  IF PrintTransfer Then
    Select Case eSourceLocation.Text
      Case "CHC"
        msgbox("To Be Setup to Print to Christchurch Printer")
      Case "HAM"
        msgbox("To Be Setup to Print to Hamilton Printer")
    End Select

    PrintTransf = TransfData.Print
'    PrintTransf.ReportFileName = "ICTransfer_LargeFont_LS.pfd"
    PrintTransf.ReportFileName = "ICTransfer1_BarCode.pfd"
    PrintTransf.Destination = "SCREEN"
    PrintTransf.Run
  End IF

  Status
  ForceClose = True
  Self.close
End Sub

Sub btnSave_Click
  Save(False)
End Sub

Sub btnPrint_Click
  Save(True)
End Sub

Sub SaveTransfer(Byref Post as Boolean)
  tblTransfers_Clone.IndexName = ""

  Dim TransfData as Object
  TransfData = CreateObject("Accredo.ICTransferData")
  IF DocID = 0 then
    TransfData.InsertTransfer
  Else
    IF TransfData.FindExact(DocID) then
      TransfData.Edit
    End IF
  End IF
  'NTable = BuildTable

  IF NOT ReceiptMode then ';;IF LOADMODE
    TransfData.DocumentDate = eTransferDate.value
    TransfData.ReceiptDate = eTransferDate.value
    TransfData.PeriodID = PeriodforDate(TransfData.DocumentDate)
    TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
    TransfData.SourceLocationCode = eSourceLocation.Text
    TransfData.DestinationLocationCode = eDestinationLocation.Text
    TransfData.Reference = eReference.Text


    tblTransfers_Clone.First
    TransfData.Line.Empty '--DELETE ALL LINES OFF TRANSFER

    Do until tblTransfers_Clone.Eof
      IF tblTransfers_Clone.ProductCode <> "" then ';;IF NOT NARRATIVE LINE
        TransfData.Line.Append
        TransfData.Line.ProductCode = tblTransfers_Clone.ProductCode
        IF tblTransfers_Clone.Quantity = 0 then ';;IF PRODUCT HASN'T BEEN SCANNED AT ALL AND USER HAS ACCEPTED VARIANCES IN COMPLETE TRANSFER SUB
          TransfData.Line.Quantity = tblTransfers_Clone.QuantityExpected
        Else
          TransfData.Line.QuantityDispatched = tblTransfers_Clone.Quantity
          TransfData.Line.Quantity = tblTransfers_Clone.Quantity
          TransfData.Line.Unit = tblTransfers_Clone.Unit
        End IF
        TransfData.Line.Save
      End IF
     tblTransfers_Clone.Next
    Loop
    TransfData.Save
  ElseIF ReceiptMode then
    TransfData.Line.First
    Do Until TransfData.Line.EOF
      '-----
      tblTransfers_Clone.First
      Do Until tblTransfers_Clone.EOF
        If TransfData.Line.LineID = tblTransfers_Clone.LineID then
          TransfData.Line.Edit
          TransfData.Line.QuantityReceipted = tblTransfers_Clone.QuantityExpected
          TransfData.Line.Z_Rejected = tblTransfers_Clone.Adjustment
          TransfData.Line.Save
        End IF
        IF TransfData.EOF then
          msgbox("Failed to Find matching Lines on Transfer")
          Exit Sub
        End IF
       tblTransfers_Clone.Next
      Loop
     TransfData.Line.Next
    '-----
    Loop
    TransfData.Save

  End IF

  ';;REMOVE ANY PREVIOUS NARRATIVES FOR DOCUMENT
    NTable.SetRange(TransfData.DocumentID)
    NTable.First
    Do Until NTable.EOF
      NTable.Delete
    Loop
    NTable.CancelRange

  ';;ADD NARRATIVES BACK IN AGAIN

  tblTransfers.First
  CountProd = 0
  CountNar = 0
  Do Until tblTransfers.EOF
    IF tblTransfers.ProductCode <> "" then
      CountProd = CountProd + 1
    Else
      NTable.Insert
      NTable.DocumentID = TransfData.DocumentID
      NTable.Description = tblTransfers.Description
      NTable.LineNo = CountProd + 0.01
      NTable.Save
    End IF
   tblTransfers.Next
  Loop

  If Post = True then
    IF LoadMode then
      Try
        PlayScript("Events\ICTranfer_B4PostDispatch.pfs",TransfData.DocumentID)
      Catch e
        Abort("Aborting: " & e.message)
      End Try
    End IF
    IF ReceiptMode then
      Try
        PlayScript("Events\ICTranfer_B4PostReceipt.pfs",TransfData.DocumentID)
      Catch e
        Abort("Aborting: " & e.message)
      End Try
    End IF
  End IF

  'TransfData.openform
  PrintTransf = TransfData.Print
'  PrintTransf.ReportFileName = "ICTransfer_LargeFont_LS.pfd"
    PrintTransf.ReportFileName = "ICTransfer1_BarCode.pfd"
'  Try
'    PrintTransf.Printer.PrinterName = "Hamilton - Plain"
'  Catch e
'    msgbox("Printer Error: " & e.message)
'  End Try
  'IF User.LoginUserName = "ACCREDO" then
  PrintTransf.Destination = "SCREEN"
  'PrintTransf.Printer.PrinterName = "Hamilton Plain"
  PrintTransf.Run
  Status
  ForceClose = True
  Self.close
End Sub



'Reset

Function CheckFailedLines

  IF tblTransfers.Editing then tblTransfers.Save
  LineString = ""
  tblTransfers_Clone.First
  Do Until tblTransfers_Clone.EOF
    IF tblTransfers_Clone.Quantity <> tblTransfers_Clone.QuantityExpected then
      LineString = LineString & tblTransfers_Clone.ProductCode & " - QTY: " & tblTransfers_Clone.Quantity & " EXPECTED: " & tblTransfers_Clone.QuantityExpected & IIF(tblTransfers_Clone.OriginalUnit <> tblTransfers_Clone.Unit,"   - Unit Changed from " & tblTransfers_Clone.OriginalUnit & " to " & tblTransfers_Clone.Unit,"") & chr(13)
    End IF
   tblTransfers_Clone.Next
  Loop


 Return LineString

End Function

Sub DeleteLine

  IF tblTransfers.ProductCode = "" AND tblTransfers.LineID = 0 then

    Exit Sub
  End IF

  IF InputQuery("Are you sure you want to delete Product " & tblTransfers.ProductCode & " from the Transfer List?") then
    IF tblTransfers.LineID <> 0 AND DocID <> 0 then
      IF ICTFER.FindExact(DocID) then
        LN = ICTFER.Line
        LN.First
        Do Until LN.EOF
          IF LN.LineID = tblTransfers.LineID then
            ICTFER.Edit
            LN.Delete
            ICTFER.Save
            Exit Do
          End IF
         LN.Next
        Loop
      Else
        self.showerrorhint("Logic Error: Can't Find DocumentID: " & DocID)
        Abort("",True)
      End IF
    Else
      ';;Just Delete off tblTransfers
    End IF
  Else
    Abort("",True)
  End IF

End Sub


Function CreateTable

  Dim Builder as Object
  Builder = CreateObject("Accredo.MemoryTableBuilder")
  Dim NewField as Object
  NewField = Builder.AddField("ProductCode", "IC Product Code")
  NewField = Builder.Addfield("Unit","Unit")
  NewField = Builder.AddField("Quantity", "Quantity")
  Builder.AddIndex("Product", "ProductCode", True)
  Dim Table as Object
  Table = Builder.CreateTable

 Return Table

End Function

Sub UpdateTransfer

  ReturnTable = CreateTable
  LN = ICTFER.Line
  tblTransfers.First

    Do Until tblTransfers.EOF
      IF LoadMode then
        IF tblTransfers.Quantity = 0 AND tblTransfers.ProductCode <> "" then
          ';;IF QUANTITIES ARE 0 WHICH MEANS THE PRODUCT WAS NOT SCANNED AND THE QUANTITIES WERE ACCEPTED

          IF InputQuery("Are you sure you want to delete Product " & tblTransfers.ProductCode & " from the Transfer List?") then

            IF tblTransfers.LineID <> 0 AND DocID <> 0 then

              IF ICTFER.FindExact(DocID) then
                ';;LOOP THROUGH TRANSFER'S LINES UNTIL IT FINDS A MATCH ON LINEID
                LN = ICTFER.Line
                LN.First
                FoundLine = False
                Do Until LN.EOF
                  IF LN.LineID = tblTransfers.LineID then
                    ICTFER.Edit
                    LN.Delete
                    ICTFER.Save
                    tblTransfers.Delete
                    Exit Do
                  End IF
                 LN.Next
                Loop
              Else
                self.showerrorhint("Logic Error: Can't Find DocumentID: " & DocID)
                Abort("",True)
              End IF 'ICTFER.Findexact

            Else
              msgbox("Logic Error: No LineID / DocID Match")
            End IF'LineID <> 0 DocID <> 0

          Else
            tblTransfers.Next
          End IF 'InputQuery to Delete
        Else 'tblTransfers.Z_QuantityUOM<> 0 but is d
          LN = ICTFER.Line
          tblTransfers.First
          ICTFER.Edit
          Do Until tblTransfers.EOF
            IF tblTransfers.Quantity <> LN.QuantityDispatched then
              LN.First
              Do Until LN.EOF
                IF LN.LineID = tblTransfers.LineID then
                  LN.Edit
                  LN.QuantityDispatched = tblTransfers.Quantity
                  LN.Save
                  Exit Do
                End IF
               LN.Next
              Loop
            End IF
           tblTransfers.Next
          Loop
          ICTFER.Save
        End IF 'tblTransfers.Z_QuantityUOM= 0

        Exit Sub

      ElseIF (tblTransfers.Quantity <> tblTransfers.QuantityExpected) AND ReceiptMode then
        ';;IF NOT LOADMODE (SO IS RECEIPTMODE)
        IF ICTFER.FindExact(DocID) then
          LN = ICTFER.Line
          LN.First
          Do Until LN.EOF
            IF LN.LineID = tblTransfers.LineID then
              ICTFER.Edit
              LN.Edit
              IF ReceiptMode then
                LN.Z_Rejected = tblTransfers.QuantityExpected - tblTransfers.Quantity
                ReturnTable.Insert
                ReturnTable.ProductCode = LN.ProductCode
                ReturnTable.Quantity = LN.Z_Rejected
                ReturnTable.Unit = LN.Unit
                ReturnTable.Save
              End IF
              LN.Save
              ICTFER.Save
              Exit Do
            Else
              ';;NO LINEID - ITEM HAS BEEN ADDED TO ORDER AT TIME OF RECEIPT - ADD TO RETURNTABLE
              ReturnTable.Insert
              ReturnTable.ProductCode = tblTransfers.ProductCode
              ReturnTable.Quantity = - tblTransfers.Quantity
              ReturnTable.Unit = tblTransfers.Unit
              ReturnTable.Save
            End IF
           LN.Next
          Loop
        End If
        tblTransfers.Next
      Else
        tblTransfers.Next
      End IF
    Loop


  ';;THE REMAINING SECTION OF CODE (UP TO END TRY) CREATES A REJECTED TRANSFER TO SEND BACK TO THE SOURCE AND MARKS IT AS DISPATCHED AND FOR ANY NEWLY ADDED ITEMS (MISS-SCAN AT DISPATCH TIME)
  ReturnTable.First
  IF ReturnTable.EOF then Exit Sub

  BeginTransaction
  Try
    Dim RTfer as Object
    RTfer = createobject("Accredo.ICTransferData")
    RTfer.IndexName = "Document"

    RTfer.InsertTransfer
    RTfer.PeriodID = periodfordate(date)
    RTfer.DocumentDate = date
    RTfer.Reference = "REJECTED TRANSFER - " & ICTfer.DocumentID
    RTfer.SourceLocationCode = ICTfer.DestinationLocationCode
    RTfer.TransitLocationCode = ICTfer.TransitLocationCode
    RTfer.DestinationLocationCode = ICTfer.SourceLocationCode

    RLog = ""
    RLN = RTfer.Line
    Do Until ReturnTable.EOF
      RLN.Append
      RLN.ProductCode = ReturnTable.ProductCode
      RLN.Unit = ReturnTable.Unit
      RLN.Quantity = ReturnTable.Quantity
      RLN.QuantityDispatched = ReturnTable.Quantity
      RLN.QuantityReceipted = ReturnTable.Quantity
      RLog = RLog & IIF(ReturnTable.Quantity < 0, ReturnTable.Quantity & " x " & ReturnTable.ProductCode & "   (INCORRECT PRODUCT SENT OR INCORRECT QTY SENT)",ReturnTable.Quantity & " x " & ReturnTable.ProductCode) & chr(13)
      RLN.Save
     ReturnTable.Next
    Loop

    RTfer.Save

    RLN.First

    Do Until RLN.EOF
      NTable.Append
      NTable.DocumentID = RTfer.DocumentID
      NTable.LineNo = RLN.LineNo + 0.01
      Desc1 = "Stock Taken from " & RTfer.DestinationLocationCode
      Desc2 = "Stock Returned to " & RTfer.DestinationLocationCode
      NTable.Description = IIF(RLN.Quantity < 0,Desc1,Desc2)
      NTable.Save
     RLN.Next
    Loop
    PlayScript("Events\ICTranfer_B4PostDispatch.pfs",RTfer.DocumentID)
    CommitTransaction
    msgbox("Rejected/Replacement Transfer Created and Dispatched for the Following Products: " & chr(13) & chr(13) & RLog)
  Catch e
    RollBackTransaction
    msgbox("Error creating reject transfer: " & e.message & " - Source: " & e.sourcepos)
  End Try
'  openForm("ICTFER",RTfer.DocumentID)


End Sub


Sub CompleteTransfer

  IF InputQuery("Are you sure you want to " & btnComplete.Caption & " the Transfer?") then
    ';; Do Nothing
  Else
    btnComplete.showerrorhint("Aborted")
    Abort("",True)
  End IF

  CheckUOM
  IF Contin = False then
    'Msgbox("Quantity (" & tblTransfers.Z_QuantityUOM & ") on Product " & tblTransfers.ProductCode & " is not a round number, please correct before proceeding")
    tblTransfers.ShowFieldErrorHint("Quantity (" & tblTransfers.Quantity & ") on Product " & tblTransfers.ProductCode & " is not a round number, please correct before proceeding","Quantity")
    Exit Sub
  END IF

  IF OpenExisting = True then
    Log = CheckFailedLines

    IF Log <> "" then
        IF InputQuery("The Following Products Have Different Quantities to the Original Transfer: " & chr(13) & _
                      Log & chr(13) & _
                      IIF(LoadMode,"Would You Like to Proceed With The Current Quantities?","Would You Like to Proceed With The Current Quantities and Reject and Return the Variances?" & chr(13) & chr(13) & _
                      "This will create a transfer for the variances back to the dispatch location")) then
          UpdateTransfer
        Else
          IIF(LoadMode,btnComplete.ShowErrorHint("Dispatch Aborted"),btnComplete.ShowErrorHint("Complete Aborted"))
          Exit Sub
        End IF
    Else
      btnComplete.ShowStatusHint("All Lines Complete")
    End IF
  End IF


  'TransferExitForm = Createcustomform("Barcoding\TransferExitForm.pfd")
  'TransferExitForm.ShowModal
  'Dim ExitStatus as String
  'ExitStatus = TransferExitForm.pExitStatus
  'If ExitStatus = "TransferAndPost" then
    SaveTransfer(True)
  '  Reset
  'ElseIf ExitStatus = "Transfer" then
   ' SaveTransfer(False)
   ' Reset
  'ElseIf ExitStatus = "Close" then
  'Else
  'Error("Exit Status Unkown")
  'End IF
  eBarcode.SetFocus
End Sub


Sub OnEnter
  eBarcode.Text = ""
End Sub


Sub OnLeave
  IF SourceLocation and DestinationLocation and eBarcode.text = "000000000000" then
'    GenerateInvoice
  ElseIF eBarcode.text <> "" then
    IF Not StaffScan then
      if Upper(LEFT(eBarcode.value,5)) = "STAFF" Then
        eReference.Text = Upper(Mid(eBarcode.value,6,20))
        StaffScan = True
      Else
        eBarcode.Showerrorhint("Scan Staff")
      End IF
    Else
      ProductScanCheck
    End IF
  End IF
  Status
IF eBarcode.Text <> "" then eBarcode.SetFocus
End Sub


Sub ChangeQuantity

  tblTransfers_Clone.Fields.Item("ProductCode").Readonly = False
  tblTransfers_Clone.Fields.Item("Quantity").Readonly = False
  tblTransfers_Clone.Fields.Item("Unit").Readonly = False


  If eproductCode.text <> "" then
      'tblTransfers.indexname = "Product"
      IF tblTransfers_Clone.Findexact(eproductCode.text) then
        CalcForm = Createcustomform("Barcoding\Qty_Entry.pfd")
        CalcForm.pProductCode = eproductCode.text
        CalcForm.pOrder = False
  '      CalcForm.pOrderedQTY = tblTransfers.QuantityOrdered
  '      CalcForm.pLPickedQty = tblTransfers.QuantityOutstanding
        CalcForm.ShowModal
        IF CalcForm.eExitStatus.Checked = True Then
          btnButton2.showstatushint("Cancelled")
          IF Not InsertMode then
            tblTransfers_Clone.Fields.Item("ProductCode").Readonly = True
            tblTransfers_Clone.Fields.Item("Quantity").Readonly = True
            tblTransfers_Clone.Fields.Item("Unit").Readonly = True
          End IF
          Exit Sub
        End IF
        tblTransfers_Clone.Edit
        tblTransfers_Clone.Quantity = CalcForm.pPickedQty
        Try
          tblTransfers_Clone.Adjustment = tblTransfers_Clone.QuantityExpected - tblTransfers_Clone.Quantity
        Catch
        End Try
  '      tblTransfers.QuantityOutstanding = tblTransfers.QuantityOrdered - tblTransfers.QuantityScanned
        tblTransfers_Clone.Save
        'tblTransfers.IndexName = "Product"
        ProductDetails
      Else
        eBarcode.Showerrorhint("Item Not Found On Transfer: " & eProductCode.Text)
      End IF
  Else
    eproductCode.Showerrorhint("Scan Product First")
  End IF

  IF Not InsertMode then
    tblTransfers_Clone.Fields.Item("ProductCode").Readonly = True
    tblTransfers_Clone.Fields.Item("Quantity").Readonly = True
    tblTransfers_Clone.Fields.Item("Unit").Readonly = True
  End IF
  eBarcode.SetFocus

  tblTransfers.Refresh
End SUb

Sub Ref_Leave
  eBarcode.SetFocus
';;DISABLED TEMPORARILY AS THE SAVE BUTTON IS HAVING TO BE CLICKED TWICE IF COMING FROM THE REFERENCE BOX
End Sub



Sub AddNewItem
  IF not SourceLocation Then
    eBarcode.Showerrorhint("Scan Source Location")
  ElseIF not DestinationLocation Then
    eBarcode.Showerrorhint("Scan Destination Location")
  ElseIf not StaffScan Then
    eBarcode.Showerrorhint("Scan Staff Reference")
  Else
    AddNewItemForm = Createcustomform("Barcoding\OrderPicking_AddProductToOrder.pfd")
    AddNewItemForm.ShowModal
    Dim NewProduct as String
    NewProduct = AddNewItemForm.pNewProduct
    NewBarcode = AddNewItemForm.pNewBarcode
    If NewProduct <> "" then
      tblTransfers.AllowInsertDelete = True
      tblTransfers.Append
      'tblTransfers.NewRow = True
      tblTransfers.ProductCode = NewProduct
      eproductCode.text = NewProduct
      IF ICPROD.Findexact(NewProduct) then
        tblTransfers.Description = ICPROD.DEscription
      End IF

       tblTransfers.Quantity = 1

  '    tblTransfers.QuantityPicked = 1
  '    tblTransfers.QuantityOrdered = 1
      tblTransfers.Save
      'tblTransfers.AllowInsertDelete = False
    End IF
    Call ProductDetails
  '  tblTransfers.indexname = "Order"
    eBarcode.SetFocus
  End IF
End SUb



Sub navGrid_Click(Sender as Object,Button as Number, Handled as Boolean)

  IF Button = ebDelete  then
    DeleteLine
  End IF

End Sub]]>
</Design>
