  <![CDATA[Sub Order

  IF Company.CompanyMenuName = "PLAY - DBNZ"  Then
   'IF User.LoginUserName = "ACCREDO" Then
    MSGBOX("Order Play")
    CreateCustomForm("Barcoding\OrderPickingBarcode_test.pfd")
'    CreateCustomForm("Barcoding\OrderPickingBarcode_modify.pfd")
  Else
'    IF User.LoginUserName = "ACCREDO" Then Msgbox(Company.CompanyMenuName)
    CreateCustomForm("Barcoding\OrderPickingBarcode.pfd")
  End If
End Sub

