Reset

Sub CompleteStockTake
  IF InputQuery("Are you sure you want to complete?") Then
    WaitCursor(True)
    IF CountID = 0 Then
      Dim ICStocktakeData as Object
      ICStocktakeData = CreateObject("Accredo.ICStocktakeData")
      ICStocktakeData.indexname = "Document"
      IF ICStocktakeData.Findexact(eStocktakeID.Value) Then
        Dim ICStocktakeCountData as object
        ICStocktakeCountData = CreateObject("Accredo.ICStocktakeCountData")
        ICStocktakeCountData.InsertCount(eStocktakeID.Value)
        ICStocktakeCountData.Details = "Scanned By:" & User.LoginUserName
        tblExport.First
        Do until tblExport.Eof
          ICStocktakeCountData.Line.Append
          ICStocktakeCountData.Line.ProductCode = tblExport.ProductCode
          ICStocktakeCountData.Line.QuantityCounted = tblExport.Quantity
          ICStocktakeCountData.Line.Save
         tblExport.Next
        Loop
        ICStocktakeCountData.Save
        btnComplete.ShowStatusHint("Count Entered")
        btnComplete.Enabled = False
        ICStocktakeCountData.Confirmed
        ForceClose = True
        self.close
      Else
        Throw "Logic Error Unable to Find Stocktake"
      End IF
    Else
      IF ICCountData.Editing Then ICCountData.Save
      IF ICCountData.FindExact(CountID) Then
        LN = ICCountData.Line

        If not ICCountData.Editing then ICCountData.Edit

        tblExport.First
        Do Until tblExport.EOF
          LN.First

          IF tblExport.IsNew Then
            LN.Append
            LN.ProductCode = tblExport.ProductCode
            LN.QuantityCounted = tblExport.Quantity
            LN.Save
          Else
            Do Until LN.EOF
              IF LN.ProductCode = tblExport.ProductCode Then
                LN.Edit
                LN.QuantityCounted = tblExport.Quantity
                LN.Save
                Exit Do
              End IF
             LN.Next
            Loop
          End IF
         tblExport.Next
        Loop

        IF ICCountData.Editing Then ICCountData.Save

        IF IsVariance Then 'ON A VARIANCE COUNT
          tblExport.IndexName = "Product"
          ICSTData.SetRange(ICCountData.DocumentID) 'SET IC STOCKTAKES TO ONLY LOOK AT THE VARIANCE COUNT'S PARENT STOCKTAKE COUNTS
          ICSTData.Count.First 'LOOP THROUGH ALL COUNTS FOR STOCKTAKE
          Do Until ICSTData.Count.EOF
            IF NonV_CountData.FindExact(ICCountData.DocumentID,ICSTData.Count.CountID) Then 'FIND COUNTDATA FOR COUNTID
              IF NonV_CountData.CountID <> ICCountData.CountID Then 'CHECK COUNT ISN'T THIS VARIANCE COUNT
                NonV_CountData.Line.First
                Do Until NonV_CountData.Line.EOF 'LOOP THROUGH FOUND COUNT LINES AND LOOK FOR PRODUCTS ON tblEXPORT, IF FOUND, ZERO QUANTITYCOUNTED
                  IF tblExport.FindExact(NonV_CountData.Line.ProductCode) Then
                    NonV_CountData.Edit
                    NonV_CountData.Line.Edit
                    NonV_CountData.Line.QuantityCounted = 0
                    NonV_CountData.Save
                  End IF
                 NonV_CountData.Line.Next
                Loop
              End IF
            End IF
           ICSTData.Count.Next
          Loop

          ICSTData.CancelRange
        End IF

        WaitCursor(False)
        IF ICCountData.CountStatus = "U" then
          IF InputQuery("Mark Count as Confirmed?") Then ICCountData.Confirmed
        End IF

        IF AutoOpen = True Then
          CTable = ExecuteSQL("Select DocumentID, CountID, Details, CountStatus FROM ICCNTHD WHERE DocumentID = :STKID ", ICCountData.DocumentID)
          IF right(CTable.Details,len("Bin Location 2")) <> "Bin Location 2" Then
            CallingForm = getNamedObject("IC_OPENST_FORM")
            IF not isnull(callingform) and not isempty(callingform) Then CallingForm.OpenNextForm.Checked = NOT CallingForm.OpenNextForm.Checked
          End IF
        End IF

      Else
        Throw "Logic Error: Unable to Find Stocktake Count"
      End IF
    End IF
    WaitCursor(False)
    ForceClose = True
    self.Close
  End IF


