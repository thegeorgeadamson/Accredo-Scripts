  <![CDATA['Imports "API\CheckPredefined.pfs"

gridEditGrid1.Align = alClient
ISVariance = False
tblEAN128.indexname = "FieldID"
CreditorSet = False
ForceClose = False
eScan_Barcode = ""
eScan_Quantity = 0
eBarcode.SetFocus
Dim Bin as String
Dim Preindex as String
Dim ProdCnt as Boolean

Bin = ""
Location = ""
CountID = 0
DocID = 0
AutoOpen = False

Dim ExistingCount as Object

Dim ICPROD as OBJECT
ICPROD = Opentable("ICPROD")
ICPROD.indexname = "Product"

Dim ICBAR as OBJECT
ICBAR = Opentable("ICBAR")
ICBAR.indexname = "Barcode"

Dim ICQTY as OBJECT
ICQTY = Opentable("ICQTY")
ICQTY.indexname = "ProductLocation"

Dim ICCountData as Object
ICCountData = createobject("Accredo.icstocktakecountdata")
ICCountData.IndexName = "Count"

Dim NonV_CountData as Object
NonV_CountData = createobject("Accredo.icstocktakecountdata")
NonV_CountData.IndexName = "DocumentCount"

Dim ICSTData as Object
ICSTData = createobject("Accredo.icstocktakedata")
ICSTData.IndexName = "Document"




If scriptargs.count = 3 Then
  Location = Scriptargs[1]
  Bin = Scriptargs[2]
ElseIF scriptargs.count = 5 Then
  Location = ScriptArgs[1]
  Bin = ScriptArgs[2]
  CountID = ScriptArgs[3]
  AutoOpen = ScriptArgs[4]
End if

Sub btnDelete_Click

  IF InputQuery("Remove Line with ProductCode: " & tblStockTake.ProductCode & "?","Remove Line from Stocktake?") = True then

    tblStockTake.AllowInsertDelete = True

    tblStockTake.Delete

    tblStockTake.AllowInsertDelete = False

  End IF



End Sub


sub ConfirmClose
  IF ForceClose = False then
    If Not inputquery("Confirm Close") then
      abort("",True)
    End IF
  End IF
End SUb

