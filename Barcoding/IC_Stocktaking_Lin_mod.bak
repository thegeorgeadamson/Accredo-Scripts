Sub OnEnter
  eBarcode.Text = ""
End Sub

Sub OnLeave

  IF CreditorSet and eBarcode.text = "000000000000" then
    CompleteStockTake
  ElseIF eBarcode.text <> "" then
    ProductScanCheck
  End IF
IF eBarcode.Text <> "" then eBarcode.SetFocus
End Sub

sub OnCalcCellColors(Sender as Object, Field as Object, Row as Number, Highlight as Boolean, CellFont as Object, ByRef BackColor as Number)

   IF tblStocktake.productcode = eProductCode.text Then
     BackColor = 65535 '3158271  '12701121 '13481613  '16760576
     CellFont.Bold = False
   End If
   MSGDisp = False

End Sub

Sub Ref_Leave
  eBarcode.SetFocus
End Sub

