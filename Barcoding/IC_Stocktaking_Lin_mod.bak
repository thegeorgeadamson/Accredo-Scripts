Function getVariance(Table)

  'Msgbox(Table.Quantity & " " & table.QuantityInStock & " " & Table.ExistingCount)

  Return (Table.Quantity - Table.QuantityInStock) + Table.ExistingCount


End Function

Private Sub PopulateGrids(byref table as Object, byref memTable as Object, byref cloneTable as Object)
'  BrowseDataSet(cloneTable)
  'table.ReadOnly = False
'  ReadAllow
'  Msgbox(table.Name)
  ISVariance = False

  IF ICCountData.FindExact(CountID) Then
    IF left(ICCountData.Details,8) = "Variance" Then
      ISVariance = True
      tblStocktake.Fields.Item("ExistingCount").Visible = False
    End IF
  End IF

  cloneTable.empty
  memTable.First
  Do Until memTable.EOF
    CloneTable.Append
    IF ICPROD.Findexact(memTable.ProductCode) then
      cloneTable.Description = ICPROD.Description
    End IF

    CopyFieldsByName(memTable, cloneTable)
    IF ExistingCount.FindExact(memTable.ProductCode) Then
      IF IsVariance Then
        CloneTable.Quantity = CloneTable.ExistingCount + ExistingCount.QuantityCounted
        CloneTable.Variance = getVariance(cloneTable)
      Else
        CloneTable.ExistingCount = CloneTable.ExistingCount + ExistingCount.QuantityCounted
        CloneTable.Variance = getVariance(cloneTable)
      End IF
    End IF


    CloneTable.Save
   memTable.Next
  Loop
'  msgbox(Location)
  If Location = "DBNZ" OR Location = "WGTN" Then
    Table.Indexname = "DBNZBinProduct"
  else
    Table.Indexname = "BinProduct"
  end iF
  table.refresh
  table.First

End Sub


Sub Load_Form

  'msgbox(eLocationCode.value)

  If scriptargs.count <= 1 Then
    Dim Form as Object
    Form = CreateObject("Accredo.ScriptedForm")
    Form.Caption = "New Stocktake Form"
    Form.InputCode("Location","ICLOCN", "Location")
    Form.inputbox("Bin","Bin")
    Do
      If Form.Execute Then
        Location = Form.GetValue("Location")
        Bin = Form.GetValue("Bin")
        If Location <> "" Then
          Exit Do
        Else
          MsgBox("Please select a Location code")
        End If
      Else
        Abort("Cancelled by User")
      End If
    Loop
    eLocationCode.text = Location
    ebinloc.text = Bin
  else

  end If


    DIM ICQTY as Object

    IF CountID = 0 Then
      ICQTY = Executesql(" Select ICQTY.ProductCode " & chr(13) & _
                         "       ,ICQTY.Binlocation " & chr(13) & _
                         "       ,(ICQTY.Z_BinLocation2) as BinLocation2 " & chr(13) & _
                         "       ,ICQTY.QuantityInstock " & chr(13) & _
                         "       ,(ICQTY.StocktakeVariance - ICQTY.QuantityInstock) as Variance " & chr(13) & _
                         "       ,ICQTY.QuantityAllocated " & chr(13) & _
                         "       ,Cast(0 as Integer) as DocID " & _
                         "       ,ICQTY.DateOfLastReceipt as DateOfLastReceipt " & _
                         " FROM   ICPROD " & chr(13) & _
                         "        INNER JOIN ICQTY  ON ICPROD.ProductCode=ICQTY.ProductCode " & chr(13) & _
                         " WHERE (ICPROD.Inactive = False) " & chr(13) & _
                         "   And (ICPROD.Nondiminishing = False) " & chr(13) & _
           IIF(Bin=""," ","   AND ICQTY.Binlocation = '" & Bin & "'") &_
                         "   And ICQTY.LocationCode = :Loc " & IIF(LOcation = "DBNZ" OR Location="WGTN","ORDER BY ICBIN.BinLocation",""), Location)

  '        IIF(Bin=""," ","   AND (ICQTY.Binlocation = '" & Bin & "' or ICQTY.Z_BinLocation2 = '" & Bin & "') ") &_

    Else
      IF ICCountData.FindExact(CountID) Then
        Location = ICCountData.LocationCode
        ICQTY = ExecuteSQL(" Select ICCNTLN.ProductCode " & chr(13) & _
                         "       ,max(ICQTY.Binlocation) as BinLocation " & chr(13) & _
                         "       ,Max(ICQTY.Z_BinLocation2 as BinLocation2 " & chr(13) & _
                         "       ,sum(ICQTY.QuantityInstock) as QuantityInStock " & chr(13) & _
                         "       ,(sum(ICQTY.StocktakeVariance) - sum(ICQTY.QuantityInstock)) + max(ICCNTLN.QuantityCounted) as Variance " & chr(13) & _
                         "       ,min(ICCNTLN.QuantityCounted) as Quantity " & chr(13) & _
                         "       ,sum(ICQTY.QuantityAllocated) " & chr(13) & _
                         "       ,ICCNTLN.LineNo " & chr(13) & _
                         "       ,max(ICCNTLN.DocumentID) as DocID " & chr(13) & _
                         "       ,max(ICQTY.DateOfLastReceipt) as DateOfLastReceipt " & _
                         " FROM   ICCNTHD " & chr(13) & _
                         "        INNER JOIN ICCNTLN ON ICCNTHD.CountID=ICCNTLN.CountID " & chr(13) & _
                         "        INNER JOIN ICQTY ON ICCNTLN.ProductCode=ICQTY.ProductCode " & chr(13) & _
                         "        INNER JOIN ICPROD ON ICCNTLN.ProductCode=ICPROD.ProductCode " & chr(13) & _
                         " WHERE (ICPROD.Inactive = False) " & chr(13) & _
                         "   And (ICPROD.Nondiminishing = False) " & chr(13) & _
                         "    AND ICCNTHD.CountID = :ID " & chr(13) & _
                         "    AND ICQTY.LocationCode = :Location " & chr(13) & _
                         " Group By ICCNTLN.ProductCode,ICCNTLN.LineNo " & IIF(LOcation = "DBNZ" OR Location="WGTN",",ICQTY.Binlocation ORDER BY BinLocation",""), CountID,Location)
            eLocationCode.text = Location
            ebinloc.text = Bin

            eStocktakeID.Text = ICCountData.DocumentID
        End IF
    End IF

    ICQty.First
    Do Until ICQty.EOF
      IF ICQty.DocID <> 0 Then
        DocID = ICQty.DocID
        Exit Do
      End IF

     ICQty.Next
    Loop
'    browsedataset(ICQTY)
    IF Left(ICCountData.Details,8) = "Variance" Then
      ExistingCount = ExecuteSQL("Select min(ProductCode) as ProductCode, sum(QuantityCounted) as QuantityCounted FROM ICCNTLN WHERE DocumentID = :DocID Group By ProductCode", DocID, CountID)
    Else
      ExistingCount = ExecuteSQL("Select min(ProductCode) as ProductCode, sum(QuantityCounted) as QuantityCounted FROM ICCNTLN WHERE DocumentID = :DocID AND CountID <> :CountID Group By ProductCode", DocID, CountID)
    End IF
'    If location = "DBNZ" Then
'      ExistingCount.AddIndex("BinProduct","BinLocation;ProductCode")
'      ExistingCount.IndexName = "BinProduct"
'    else
      ExistingCount.AddIndex("Product","ProductCode")
      ExistingCount.IndexName = "Product"
'    end IF

    PopulateGrids(tblStocktake, ICQTY, tblStocktake_Clone)

'    Browsedataset(tblStocktake)

    tblStocktake.Fields.Item("ProductCode").ReadOnly = True

    tblvariance =  Executesql("SELECT   ICPROD.ProductCode " & _
                        "        ,Sum(ICPEND.Quantity) As Qty" & _
                        "        ,ICPEND.LocationCode " & _
                        "        ,ICPEND.SourceModule " & _
                        "FROM   ICPROD " & _
                        "       INNER JOIN ICPEND  ON ICPROD.ProductCode=ICPEND.ProductCode " & _
                        "WHERE  ICPEND.SourceModule IN('IN','OE') " & _
                        "   And (ICPEND.LocationCode = :Loc) " &_
                        "GROUP BY ICPROD.ProductCode " & _
                        "        ,ICPEND.LocationCode " & _
                        "        ,ICPEND.SourceModule ", Location)
  '  Browsedataset(tblStocktake)

    tblStocktake.indexname = "Product"
      tblvariance.First
      Do Until tblvariance.EOF

        IF tblStocktake.Findexact(tblvariance.Productcode) then
            tblStocktake.Edit
          If tblvariance.SourceModule = "OE" Then tblStocktake.AlloOE = tblvariance.QTY * -1
          If tblvariance.SourceModule = "IN" Then tblStocktake.AlloIN = tblvariance.QTY * -1
          tblStocktake.Save
        End IF


       tblvariance.Next
      Loop
  If location = "DBNZ" OR Location = "WGTN" Then
    tblStocktake.indexname = "DBNZBinProduct"
  else
    tblStocktake.indexname = "BinProduct"
  end IF

  tblStocktake.Fields.Item("ProductCode").ReadOnly = True
  eBarcode.SetFocus

End Sub

Sub Reset
  StaffScan = False
  eDocID.Value = 0
  tblStocktake.Empty
  btnComplete.Enabled = True
End Sub
Reset

tblStocktake.AllowInsertDelete = False
'eTransferDate.Value = Systemdate

Sub ProductDetails
  IF ICPROD.FIndexact(tblStocktake.ProductCode) then
    eProductCode.Text = ICPROD.ProductCode
    eProductName.Text = ICPROD.Description
    'eInStock.Value = ICPROD.QuantityInStock
    IF ICQTY.Findexact(tblStocktake.ProductCode, eLocationCode.text) THen
      eInStock.Value = ICQTY.Quantityinstock
    Else
      eInStock.Value = 0
    End IF
    if ApplicationSetting( "IC\ValuationBasis") = "L" Then
      eCostPrice.Text = formatNumber(ICPROD.LatestCost,"Amount")
    Elseif ApplicationSetting( "IC\ValuationBasis") = "A" Then
      eCostPrice.Value = ICPROD.AverageCost
    Elseif ApplicationSetting( "IC\ValuationBasis") = "S" Then
      eCostPrice.Value = ICPROD.StandardCost
    End IF
  End IF
  ePicked.Value = tblStocktake.Quantity
End Sub


Sub btnAssignBarcode_Click

'  eBarcode.SetFocus
'  AssignBarcodeForm = CreateCustomForm("BinLocation_Quick_Input_EAN128.pfd")
End Sub




Sub ChangeQuantity
  PreIndex = tblStocktake.IndexName
If eproductCode.text <> "" then
    tblStocktake.indexname = "Product"
    IF tblStocktake.Findexact(eproductCode.text) then
      CalcForm = Createcustomform("Barcoding\Qty_Entry.pfd")
      CalcForm.pProductCode = eproductCode.text
      CalcForm.pOrder = False
'      CalcForm.pOrderedQTY = tblStocktake.QuantityOrdered
'      CalcForm.pLPickedQty = tblStocktake.QuantityOutstanding
      CalcForm.ShowModal
      IF CalcForm.eExitStatus.Checked = True Then
        btnButton2.showstatushint("Cancelled")
        Exit Sub
      End IF

      tblStocktake.Edit
      tblStocktake.Quantity = CalcForm.pPickedQty
      tblStocktake.Variance = getVariance(tblStockTake) 'tblStocktake.Quantity - tblStocktake.QuantityInStock
'      tblStocktake.QuantityOutstanding = tblStocktake.QuantityOrdered - tblStocktake.QuantityScanned
      tblStocktake.Save
      ProductDetails
    Else
      eBarcode.Showerrorhint("Item: " & eProductCode.Text & " Not Found In This Location")
    End IF
Else
  eproductCode.Showerrorhint("Scan Product First")
End IF
  tblStocktake.IndexName = PreIndex
  eBarcode.SetFocus
End SUb

Function IsZeal
  Return User.LoginUserName = "ACCREDO"
End Function

Sub Product_Count_Check

  ProdCnt = False

  Dim tblICSTKHD as Object
  tblICSTKHD = OpenTable("ICSTKHD")
  tblICSTKHD.IndexName = "Document"

  If tblICSTKHD.FindExact(eStocktakeID.value) Then

  End if

  Dim tblICSTKLN as Object
  tblICSTKLN = OpenTable("ICSTKLN")
  tblICSTKLN.IndexName = "StatusProductPeriodLocation"

  If tblICSTKLN.FindExact("U",eProductCode.Text,tblICSTKHD.PeriodId,eLocationCode.text) Then
    ProdCnt = True
  End if

  If tblICSTKLN.FindExact("C",eProductCode.Text,tblICSTKHD.PeriodId,eLocationCode.text) Then
    ProdCnt = True
  End if

'Msgbox("prod Cnt Flag = " & ProdCnt)

End Sub

Sub DoProcessProduct
  SetFocusToHolding = False
  PreIndex = tblStocktake.IndexName
  tblStocktake.IndexName = "Product"
  IF ICPROD.FIndexact(eProductCode.Text) then
        eProductName.Text = ICPROD.Description
        IF ICPROD.NonDiminishing <> True then
          IF Not ICPROD.Inactive then
            IF tblStocktake.Findexact(eProductCode.Text) then
              tblStocktake.Edit
              tblStocktake.Quantity = tblStocktake.Quantity + eScan_Quantity
              tblStocktake.Variance = getVariance(tblStocktake) 'tblStocktake.Quantity - tblStocktake.QuantityInStock
              tblStocktake.Save
              ProductDetails

            ElseIF IsVariance Then'IF tblStocktake.Findexact(eProductCode.Text) then
              Dim SCForm as Object
              SCForm = CreateObject("Accredo.ScriptedForm")
              SCForm.Caption = "Not a Variance Product"
              SCForm.ShowText("No variance is available for: ")
              SCForm.ShowText("  Product: " & ICProd.ProductCode)
              SCForm.ShowText("  Description: " & ICProd.Description)
              SCForm.ShowText("Add to variance count?")
              Do
                If SCForm.Execute Then
                  tblStocktake.AllowInsertDelete = True
                  tblStocktake.Append
'                  IF ICQTY.Findexact(eProductCode.Text,eLocationCode.text) Then
                    tblStocktake.Fields.Item("ProductCode").ReadOnly = False
                    tblStocktake.ProductCode = eProductCode.Text
                    tblStocktake.Fields.Item("ProductCode").ReadOnly = True
                    tblStocktake.Description = ICPROD.Description
                    tblStocktake.Quantity = tblStocktake.Quantity + eScan_Quantity
                    tblStocktake.Variance = getVariance(tblStocktake) 'tblStocktake.Quantity - tblStocktake.QuantityInStock
                    tblStocktake.IsNew = True
                    tblStocktake.Save
                    tblStocktake.AllowInsertDelete = False
                    ProductDetails
'                  Else
'                    MSGBOX("Location - " & eLocationCode.text & " not valid for product Code " & eProductCode.Text & chr(13) & "No Such Product at this Location")
'                    Dim ICProdLoc as Object
'                    ICProdLoc = CreateObject("Accredo.ICProductData")
'                    ICProdLoc.indexName = "Product"
'                    If ICProdLoc.FindExact(eProductCode.Text) Then
'                       ICProdLoc.Edit
'
'                       ICProdLoc.Save
'                    End If
'                    'Exit Do
'                  End If
                  Exit Do
                Else
                  Exit Do
                End If
              Loop
            Else
'              MSGBOX(" Bin = " & BIN )
              Prodcnt2 = False
              IF Bin <> "" then'IF Bin <> "" then
                Product_Count_Check

                  QueryForm = Createcustomform("Barcoding\IC_StockTakeQuery.pfd")
                  QueryForm.pCode = eProductCode.Text
                  QueryForm.PLocation = eLocationCode.text
                  QueryForm.pSTPer = ProdCnt
                  QueryForm.ShowModal
                  IF QueryForm.pExitStatus = True Then
                     If ProdCnt = True Then
                        eBarcode.Showerrorhint("Product is recorded on another Stocktake")
                     Else
                        tblStocktake.AllowInsertDelete = True
                        tblStocktake.Append
                        tblStocktake.Fields.Item("ProductCode").ReadOnly = FALSE
                        tblStocktake.ProductCode = eProductCode.Text
                        tblStocktake.Fields.Item("ProductCode").ReadOnly = True
                        tblStocktake.Description = ICPROD.Description
                        tblStocktake.Quantity = tblStocktake.Quantity + eScan_Quantity
                        tblStocktake.Variance = getVariance(tblStocktake) 'tblStocktake.Quantity - tblStocktake.QuantityInStock
                        IF ICQTY.Findexact(eProductCode.Text, eLocationCode.text) Then
                          tblStocktake.Binlocation = ICQTY.Binlocation
'                          tblStocktake.BinLocation2 = ICQTY.Z_BinLocation2
                        End IF
                        tblStocktake.IsNew = true
                        tblStocktake.Save

                        tblStocktake.AllowInsertDelete = False
                        ProductDetails
      '                  ChangeQuantity
                    End If

                End If
              Else'IF Bin <> "" then
                tblStocktake.AllowInsertDelete = True
                tblStocktake.Append
'                IF ICQTY.Findexact(eProductCode.Text,eLocationCode.text) Then
                  tblStocktake.Fields.Item("ProductCode").ReadOnly = False
                  tblStocktake.ProductCode = eProductCode.Text
                  tblStocktake.Fields.Item("ProductCode").ReadOnly = True
                '                  IF ICBAR.Z_Quantity > 0 Then
                '                     tblStocktake.QuantityInStock = ICQTY.QuantityInStock * ICBAR.Z_Quantity
                '                  Else
                '                     tblStocktake.QuantityInStock = ICQTY.QuantityInStock
                '                  End If
                  tblStocktake.Description = ICPROD.Description
                  tblStocktake.Quantity = tblStocktake.Quantity + eScan_Quantity
                  tblStocktake.Variance = getVariance(tblStocktake) 'tblStocktake.Quantity - tblStocktake.QuantityInStock
                '                  IF ICQTY.Findexact(eProductCode.Text, Location) Then
                '                    tblStocktake.Binlocation = ICQTY.Binlocation
                '  '                  tblStocktake.BinLocation2 = ICQTY.Z_BinLocation2
                '                  End IF
                '
                  tblStocktake.IsNew = True
                  tblStocktake.Save
                  tblStocktake.AllowInsertDelete = False
                  ProductDetails

'                Else
'                  MSGBOX("Location - " & eLocationCode.text & " not valid for product Code " & eProductCode.Text & chr(13) & "No Such Product at this Location")
'                End If
  '                ChangeQuantity

              End IF'IF Bin <> "" then
            End IF'IF tblStocktake.Findexact(eProductCode.Text) then

'            eBarcode.ShowStatusHint(eScan_Quantity & " x " & eProductCode.Text & " Added")
          Else'IF Not ICPROD.Inactive then
            eBarcode.Showerrorhint("Product is Inactive")
          End IF
        Else
          eBarcode.Showerrorhint("Product is No Diminishing")
        End IF
      Else
      eBarcode.Showerrorhint("Product Not Found")

'        eBarcode.Showerrorhint("eProductName.Text = ""
      End If
  tblStocktake.IndexName = PreIndex
End Sub

Sub ProductScanCheck

  PreIndex = tblStocktake.IndexName
  IF ICBAR.Findexact(eBarcode.text) then
    eProductCode.Text = ICBAR.ProductCode
    eScan_Quantity = 1
    DoProcessProduct
  ElseIF ICPROD.Findexact(eBarcode.Text) Then
    eProductCode.Text = ICPROD.ProductCode
    tblStocktake.indexname = "Product"
    eScan_Quantity = 1

    doProcessProduct
  Else

'    CheckPredefined(eBarcode.Text,tblEAN128)
'    eScan_Barcode = CPD_Barcode
'    eScan_Quantity = CPD_Weight
'    tblStocktake.indexname = "Product"
'
'    IF CPD_ProdCode <> "" then
'        eProductCode.Text = CPD_ProdCode
'        DoProcessProduct
'    Else
'      eBarcode.Showerrorhint(CPD_BarcodeStatus)
'    End IF
    eBarcode.Showerrorhint("Product Not Found")
    Createcustomform("Barcoding/BarcodeNotFound.pfd")
  End IF
  tblStocktake.IndexName = PreIndex
  eBarcode.Text = ""
  eBarcode.SetFocus
End Sub

