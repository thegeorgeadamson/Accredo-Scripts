<?xml version="1.0" encoding="UTF-8"?>
<Design Version="1" DPI="120">
  <Form Caption="frmPOExitForm_Mod" Color="clBtnFace" Constraints.MaxHeight="102399" Constraints.MaxWidth="102399" Constraints.MinHeight="125" Constraints.MinWidth="250" Font.Charset="DEFAULT_CHARSET" Font.Color="clWindowText" Font.Height="-15" Font.Name="Arial" Font.Style="" Height="777" SaveSizeName="frmOrderExitForm2" Visible="False" Width="954" WindowState="wsNormal">
