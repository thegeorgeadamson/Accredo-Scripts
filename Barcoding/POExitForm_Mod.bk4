    </TUserNumberEdit>
    <TUserEditGrid ActiveColumn="0" ActiveFocused="False" ActiveRowColor="clInfoBk" Anchors="akLeft;akTop;akRight;akBottom" Height="280" Left="1" Margins.Bottom="4" Margins.Left="4" Margins.Right="4" Margins.Top="4" Name="gridEditGrid1" Table="tblOutstanding" TabOrder="4" Top="474" Width="948">
