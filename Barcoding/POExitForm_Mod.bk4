    <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Height="26" LabelCaption="Packing Slip" Left="560" Name="ePsRef" TabOrder="10" TabStop="True" Top="31" Width="313">
