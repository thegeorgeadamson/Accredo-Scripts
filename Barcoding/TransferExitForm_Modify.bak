<?xml version="1.0" encoding="UTF-8"?>
<Design Version="1">
  <Form Caption="frmTransferExitForm_Modify" Color="clBtnFace" Constraints.MinHeight="100" Constraints.MinWidth="200" Font.Charset="DEFAULT_CHARSET" Font.Color="clWindowText" Font.Height="-12" Font.Name="Arial" Font.Style="" Height="455" OnShow="CheckTransit" SaveSizeName="frmOrderExitForm" Visible="False" Width="761" WindowState="wsNormal">
    <TUserButton Caption="Transfer &amp;&amp; Post" Height="172" ImageIndex="2080" Left="21" Name="btnButton2" OnClick="GenerateAndPrint" ShortCut="0" TabOrder="0" TabStop="True" Top="62" Width="232">
    </TUserButton>
    <TUserButton Caption="Transfer" Height="172" ImageIndex="2067" Left="262" Name="btnButton1" OnClick="Generate" ShortCut="0" TabOrder="1" TabStop="True" Top="62" Width="232">
    </TUserButton>
    <TUserButton Caption="Cancel" Height="172" ImageIndex="2074" Left="504" Name="btnButton4" OnClick="Close" ShortCut="0" TabOrder="2" TabStop="True" Top="62" Width="232">
    </TUserButton>
    <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Font.Charset="DEFAULT_CHARSET" Font.Color="clWindowText" Font.Height="-24" Font.Name="Arial" Font.Style="fsBold" Height="40" LabelCaption="Barcode" Left="227" Name="eBarcode" TabOrder="3" TabStop="True" Top="14" Width="274">
    </TUserEdit>
  </Form>
  <![CDATA[Dim IsTransit as Boolean
IsTransit = False

Sub CheckTransit

'CHECKS IF PASSED A TRANSIT LOCATION, IF SO CHANGE THE LABEL AND POST METHOD
  IF ScriptArgs.Count > 1 then
    IF ScriptArgs[1] = "TRANSIT" then
      btnButton2.Caption = "Transfer && Post Dispatch"
      IsTransit = True
    End IF
  ELSE
    btnButton2.Caption = "Transfer && Post"
    IsTransit = False
  END IF


End Sub

Sub OnEnter
  eBarcode.Text = ""
End Sub

Sub OnLeave
  IF eBarcode.text = "000000000000" then
    ExitStatus = "TransferAndPost"
    Self.Close
  End IF
End Sub

Sub GenerateAndPrint
  ExitStatus = "TransferAndPost"
  Self.Close
End Sub

Sub Generate
  ExitStatus = "Transfer"
  Self.Close
End Sub

Sub Close
  ExitStatus = "Close"
  Self.Close
End Sub

Dim ExitStatus as String
ExitStatus = ""

Property Get pExitStatus as String
  pExitStatus = ExitStatus
End Property

Property Get pIsTransit as Boolean
  pIsTransit = IsTransit
End Property]]>
</Design>
