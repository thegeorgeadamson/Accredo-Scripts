      <TUserDataCombo Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" ButtonsAvailable="dcbLookup" Enabled="True" ExactAllowEmpty="True" Height="22" LabelVisible="False" LabelWidth="0" Left="8" LookupFilter="Upper(Left(Category2,7))=&quot;FREIGHT&quot;" LookupSource="ICPROD" LookupType="ltNormal" Name="eCarrierCode" TabOrder="0" TabStop="True" Top="20" Width="135">
      </TUserDataCombo>
