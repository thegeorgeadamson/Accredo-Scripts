  End IF
'  tblOrder.indexname = "Order"
  eBarcode.SetFocus
End SUb

Sub Close
  Self.Close
End Sub

Sub AddNewItem
IF not OrderLoad Then
  eBarcode.Showerrorhint("Load Order First")
ElseIf not StaffScan Then
  eBarcode.Showerrorhint("Scan Staff")

Else
  AddNewItemForm = Createcustomform("Barcoding\OrderPicking_AddProductToOrder.pfd")
  AddNewItemForm.ShowModal
  Dim NewProduct as String
  NewProduct = AddNewItemForm.pNewProduct
  NewBarcode = AddNewItemForm.pNewBarcode
  If NewProduct <> "" then
    tblOrder.AllowInsertDelete = True
    tblOrder.Append
    tblOrder.NewRow = True
    tblOrder.ProductCode = NewProduct
    eproductCode.text = NewProduct
    IF ICPROD.Findexact(NewProduct) then
      tblOrder.Description = ICPROD.DEscription
      tblOrder.QuantityInstock = ICPROD.QuantityInstock
    End IF
    tblOrder.QuantityOutstanding = 0
    tblOrder.QuantityPicked = 1
    tblOrder.QuantityOrdered = 1
    tblOrder.Save
    tblOrder.AllowInsertDelete = False
  End IF
  Call ProductDetails
  tblOrder.indexname = "Order"
  eBarcode.SetFocus
End IF
End SUb

Sub tblOrder_BeforeDelete
  IF tblOrder.Newrow = false then
    tblToDelete.append
      CopyFieldsbyname(tblOrder,tblToDelete)
    tblToDelete.Save
  End IF
End SUb

Sub DeleteRow
  If tblOrder.RecordMax > 0 Then
    tblOrder.AllowInsertDelete = True
      tblOrder.Delete
    tblOrder.AllowInsertDelete = False
  End IF
End Sub

Sub ProductCode_OnEnter

  If tblOrder.ProductCode <> "" Then
    ProductDetails
    tblOrder.Refresh
  End IF

End Sub]]>
