  If eproductCode.text <> "" then
'      tblOrder.indexname = "Product"
''      msgbox(eproductCode.text)
'      IF tblOrder.Findexact(eproductCode.text) then
        CalcForm = Createcustomform("Barcoding\Qty_Entry.pfd")
        CalcForm.pProductCode = eproductCode.text
'        CalcForm.pOrderedQTY = tblOrder.QuantityOrdered
