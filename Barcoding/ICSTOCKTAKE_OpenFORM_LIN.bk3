Sub Variance_Count

  Dim StkData as Object
  StkData = CreateObject("Accredo.ICStocktakeData")
  StkData.indexname = "Document"

  Dim ICStkLn as object
  ICStkLn = opentable("ICSTKLN")
  ICStkLn.Indexname = "DocumentProduct"

  Dim ICCnttable as object
  ICCnttable = opentable("ICCNTHD")

  Dim StkProd as Object
  StkProd = StkData.Product

  Dim StkCount as Object
  StkCount = CreateObject("Accredo.ICStocktakeCountData")
  StkCount.indexname = "COUNT"

  Dim CountLine as Object
  CountLine = StkCount.Line

  NewCount = True
  StkData.Findexact(StktakeNo.Text)
  'MSGBOX(StktakeNo.Text)
  ICStkLn.SetRange(StktakeNo.Text)

  ICStkLn.First

  Do Until ICStkLn.EOF
    If ICStkLn.QuantityVariance <> 0 Then
      If NewCount = True Then
        NewCount = False
        StkCount.Insertcount(ICStkLn.DocumentId)
        StkCount.Details = "Variance for - " & StkData.Details

        StkCount.CountType = "A"
        StkCount.SAVE
      End If
      IF not StkCount.Editing then StkCount.Edit
        Countline.Append
        Countline.ProductCode = ICStkLn.ProductCode
  '      CountLine.Z_BinCode = ICStkln.Z_BinCode

    End If
  ICStkLn.Next
  Loop
  StkCount.Save

  If NewCount = False Then
    '[VARIANCE HAS BEEN CREATED]
    '(byref STKHDID as Number, byref Location as string, byref Bin as string, ByVal Count as Number, ByVal AutoOpen as Boolean)
    cs = 0
    cs = instrRev(StkData.Details,"Bin ")
    BL = ""

    IF cs <> 0 Then
      BL = mid(StkData.Details,cs + 4,len(StkData.Details))
    End IF


    EditCount(StkData.DocumentID,StkData.LocationCode,BL,StkCount.CountID,True)
  End IF
  Count_List
  MSGBOX("Variance Count created for Stocktake Count : " & StktakeNo.Text)
End Sub

Sub Reload_Expected_Qty

  IF ICStocktakeData.findexact(StktakeNo.Text) Then
    ICStocktakeData.Edit
    ICStocktakeData.ReloadQuantities
    ICStocktakeData.Save
    StktakeNo.ShowStatushint("Expected Quantities Re-Loaded")
  End IF
'  StktakeNo.ShowStatushint("All Expected Quantities Re-Loaded")
End Sub]]>
