  <![CDATA[self.Name = "IC_OPENST_FORM"

Dim ICStocktakeData as Object
ICStocktakeData = CreateObject("Accredo.ICStocktakeData")
ICStocktakeData.indexname = "Document"

DIM Locn as String

Dim ICSttable as object
ICSttable = opentable("ICSTKHD")

Dim ICCnttable as object
ICCnttable = opentable("ICCNTHD")
ICCnttable.IndexName = "Count"

AutoOpenCount = True

panNew.Align = alClient
panExisting.Align = alClient

Sub Count_List
  CTable = ExecuteSQL("Select DocumentID, CountID, Details, CountStatus FROM ICCNTHD WHERE DocumentID = :STKID Order By DocumentID,CountID ", val(StktakeNo.Text))

    tblCounts.Empty
    CTable.First
    Do Until CTable.EOF
      tblCounts.Append
      tblCounts.DocumentID = CTable.DocumentID
      tblCounts.CountID = CTable.CountID
      tblCounts.Details = CTable.Details
      tblCounts.CountStatus = getEnumText("IC Count Status",CTable.CountStatus)
      tblCounts.Save
     CTable.Next
    Loop

End Sub

Sub RefreshStocktakeList
  StktakeNo.Text = 0
  tblICSTKHD.Empty
  ICSttable.first
  DO until ICSttable.eof
    If ICSttable.PostStatus <> "P" and ICSttable.PostStatus <> "D" Then
      tblICSTKHD.insert
      copyfieldsbyname(ICSttable,tblICSTKHD)
      tblICSTKHD.save
    End IF
    ICSttable.next
  loop

  IF User.DefaultLocationCode <> "" then
    tblICSTKHD.IndexName = "DateLocation"
    Try
      tblICSTKHD.Last
      Do Until tblICSTKHD.BOF
'        IF tblICSTKHD.LocationCode = User.DefaultLocationCode then
        If left(tblICSTKHD.LocationCode,1)  = left(User.DefaultLocationCode,1) Then
          StktakeNo.Text = tblICSTKHD.DocumentID
          Count_List
          Exit Do
        End IF
       tblICSTKHD.Prev
      Loop
    Catch

    End Try

    ';;Reset Index
    tblICSTKHD.IndexName = "DocumentID"
  End IF

End Sub

sub formload
'  MSGBOX("Load")
  RefreshStocktakeList
  If StktakeNo.text <> "" then Count_List
end sub


sub S_Shell(URL as String)
  Shells = CreateObject("Shell.Application")
  Shells.ShellExecute(URL)
End Sub

Sub BtnOpenStocktake_Click
'  IF User.LoginUserName = "ACCREDO" then msgbox(StktakeNo.Text)
  IF ICStocktakeData.findexact(StktakeNo.Text) Then
    ICStocktakeData.Openform
  End IF
End Sub

Sub Table_Refresh
  Count_list
End Sub


Sub PrintVariance

  '## METHOD 1 ##
  IF ICStocktakeData.FindExact(StktakeNo.Text) Then

    VarRep = CreateObject("Accredo.ICStocktakeStatusReport")
    VarRep.Layout = "Stocktake Status"
    VarRep.ReportFilterSort.Filter = "DocumentID = " & StktakeNo.Text & " AND QuantityVariance <> 0"
    VarRep.Location = ICStocktakeData.LocationCode
    VarRep.Period = ICStocktakeData.PeriodID
    VarRep.Run
'    documentobject(VarRep)
  End IF


  '## METHOD 2 ##


'  IF ICStocktakeData.findexact(StktakeNo.Text) Then
'      ICStocktakeData.openform
'  End IF
'
'  ICStocktakeData.Product.FilterSort.Filter = "(QuantityVariance<>0.000)"
'
'  Form1 = ICStocktakeData.openform
'  Form1.Product.Print
'  Form1.Close

End Sub


Sub OpenHelpFile
  Dim DIR as object
  DIR = Createobject("Accredo.Directory")
  S_Shell(DIR.SystemDirectory & "Images\V4 Stocktaking.jpg")
End Sub

Sub DoNothing
End Sub


Sub Events_Clear
  eNew.OnChange = GetREf("DoNothing")
  eExisting.OnChange = GetREf("DoNothing")
End Sub


Sub Events_Set
  eNew.OnChange = GetREf("eNew_Clicked")
  eExisting.OnChange = GetREf("eExisting_Clicked")
End Sub


Sub eNew_Clicked
  Events_Clear
  panNew.Visible = True
  panExisting.Visible = False
  StktakeNo.Visible = False
  eNew.checked = True
  eExisting.checked = False
  Events_Set
  IF User.DefaultLocationCode <> "" then
    eLocation.Text = User.DefaultLocationCode
  End IF
  'eERNewRep_Change
End Sub

Sub eExisting_Clicked
  Events_Clear
  panNew.Visible = False
  panExisting.Visible = True
  StktakeNo.Visible = True
  eExisting.checked = True
  eNew.checked = False
  Events_Set
  'eERNewRep_Change
End Sub

eNew_Clicked

Sub OpenICStocktakeForm(byref STKHDID as Number, byref Location as string, byref Bin as string)

  Formstktake = Createcustomform("Barcoding\IC_Stocktaking_Lin.pfd",Location,Bin)
  Formstktake.eStocktakeID.Value = STKHDID
  Formstktake.eLocationCode.text = Location
  Formstktake.eBinloc.text = Bin
'  MSGBOX("Count List")
  Count_List

End Sub

Sub BtnOpenStocktakeList_Click

  CreateObject("Accredo.ICStocktakeListForm")

End Sub

Sub OpenNextForm
  CTable = ExecuteSQL("Select ICSTKHD.LocationCode " & _
                      ", ICCNTHD.DocumentID " & _
                      ", ICCNTHD.CountID " & _
                      ", ICCNTHD.Details " & _
                      ",ICCNTHD.CountStatus " & _
                      "FROM ICCNTHD " & _
                      "Left Join ICSTKHD ON ICCNTHD.DocumentID=ICSTKHD.DocumentID " & _
                      "WHERE ICCNTHD.DocumentID = :STKID " & _
                      "Order By CountID ", val(StktakeNo.Text))
  CTable.Last
  cs = instrRev(CTable.Details,"Bin Location 2")
  IF cs <> 0 Then

    Createcustomform("Barcoding\IC_Stocktaking_Lin.pfd",CTable.LocationCode, "", CTable.CountID, False)
  Else
'    msgbox("Error: Couldn't Automatically Open Bin Location 2 Stocktake")
  End IF
End Sub

Sub EditCount(byref STKHDID as Number, byref Location as string, byref Bin as string, ByVal Count as Number, ByVal AutoOpen as Boolean)
'abort(location)
'  Formstktake =
'  MSGBOX("Edit Count")
  Createcustomform("Barcoding\IC_Stocktaking_Lin.pfd",Location, Bin, Count, AutoOpen)

'  pnlEditCount.Visible = False
'  IF User.LoginUserName = "ACCREDO" Then MSGBOX("Return")
'  StktakeNo.text = ""
'  tblcounts.empty
'  Count_list
End Sub

Sub btnEditCount_Click

  IF pnlEditCount.Visible = False Then
    pnlEditCount.Top = 89
    pnlEditCount.Left = 169
    CTable = ExecuteSQL("Select DocumentID, CountID, Details, CountStatus FROM ICCNTHD WHERE DocumentID = :STKID Order By DocumentID,CountID ", val(StktakeNo.Text))

    tblCounts.Empty
    CTable.First
    Do Until CTable.EOF
      tblCounts.Append
      tblCounts.DocumentID = CTable.DocumentID
      tblCounts.CountID = CTable.CountID
      tblCounts.Details = CTable.Details
      tblCounts.CountStatus = getEnumText("IC Count Status",CTable.CountStatus)
      tblCounts.Save
     CTable.Next
    Loop
    CTable.First
    pnlEditCount.Visible = Not pnlEditCount.Visible
  Else
    pnlEditCount.Visible = Not pnlEditCount.Visible
  End IF

End Sub

