Sub CountSelect
  If tblCounts.CountID <> 0 Then
    If Upper(tblCounts.CountStatus) <> "UNCONFIRMED" Then
      If InputQuery("Count is marked as " & getEnumText("IC Count Status",tblCounts.CountStatus) & ", Do you want to continue?") Then
        If Upper(tblCounts.Countstatus) = "CONFIRMED" Then
          If InputQuery("Mark as UNCONFIRMED?") Then
            Dim ICCountData as Object
            ICCountdata = CreateObject("Accredo.ICStocktakeCountData")
            ICCountData.Indexname= "Count"
            If ICCountData.FindExact(tblCounts.CountID) Then
              ICCountData.Unconfirmed
            End If
            
            ICCountData = Nothing
          End If
        End If
      Else
        Abort("",True)
      End If
    End If
    pnlEditCount.Visible = False
    If ICStocktakeData.Editing then ICStocktakeData.save
    If ICStocktakeData.FindExact(tblCounts.DocumentID) Then
      '      MSGBOX(tblCounts.Details & " - " & ICStocktakeData.Z_Binlocation)
      cs = instrRev(tblCounts.Details,"Bin = ")
      '      MSGBOX("CS = " & CS)
      BL = ICStocktakeData.Z_Binlocation
      If cs <> 0 Then
        BL = mid(tblCounts.Details,cs + 6,len(tblCounts.Details))
      End If
      
      If Left(tblCounts.Details,8) = "Variance" Then
        cs = instrRev(tblCounts.Details,"Bin ")
        If cs <> 0 Then
          BL = mid(tblCounts.Details,cs + 4,len(tblCounts.Details))
        End If
      End If
      '     MSGBOX(CS & " - " & BL)
      EditCount(tblCounts.DocumentID,ICStocktakeData.LocationCode,BL,tblCounts.CountID,False)
    End If
  End If
  '  MSGBOX("Count Select")
End Sub

Sub btnCloseScanCount_Click
  
  '  eScanCount.Text = ""
  btnEditCount_Click
  
End Sub


'eDate.value = PeriodEndDate(CurrentPeriod("IC"))
eDate.value = systemdate

Sub PrintInvLevels
  If ICStocktakeData.Findexact(StktakeNo.text) Then
    Dim MyPrinter as String
    Dim InvLevelsReport as Object
    InvLevelsReport = CreateObject("Accredo.ICProductReport")
    InvLevelsReport.Layout = "Inventory Levels"
    '    msgbox(StktakeNo.text & " - " & ICStocktakeData.LocationCode)
    InvLevelsReport.Location = ICStocktakeData.LocationCode '"HAM"
    BL = ICStocktakeData.Z_BinLocation
    InvLevelsReport.ReportFilterSort.Filter = "((BinLocation=""" & BL & """) Or (Z_BinLocation2=""" & BL & """)) AND (ClosingPeriodToDate<>0.00)"
    Locn = User.DefaultLocationCode
    If Left(Locn,1) = "H" Then
      MyPrinter = "HP LaserJet Pro MFP M127-M128 PCLmS"
    ElseIf Left(Locn,1) = "C" then
      MyPrinter = "CHCH_HP M570"
    ElseIf Left(Locn,1) = "W" then
      MyPrinter = "HP Wellington"
    ElseIf Left(Locn,1) = "T" then
      MyPrinter = "OUTTGA"
    ElseIf Company.CompanyName = "DBNZ Coatings Ltd" Then
      MyPrinter = "DBA_HP_M201"
    Else
      MyPrinter = ""
    End If
    If User.LoginUserName = "ACCREDO" Then
      InvLevelsReport.Destination = "SCREEN"
      '      MSGBOX("Location = " & LOCN & " Printer= " & MYPrinter)
    Else
      InvLevelsReport.Printer.PrinterName = MyPrinter
    End If
    
    InvLevelsReport.Run
  End If
End Sub

Sub PostStocktake
  
  If StktakeNo.text = "" Then
    StktakeNo.ShowErrorHint("Select a StockTake")
    Exit Sub
  End If
  
  If ICStocktakeData.Findexact(StktakeNo.text) Then
    Try
      ICStocktakeData.Post
      btnPostStocktake.ShowStatusHint("Stockatke Posted Successfully")
      PrintInvLevels
      '      RefreshStocktakeList
      eNew.checked = True
    Catch e
      btnPostStocktake.ShowErrorHint("ERROR: " & e.message)
    End Try
    
    '()
    
  End If
End Sub

Sub CreatePendingVariance
  
  
  If ICStocktakeData.FindExact(StktakeNo.Text) Then
    If ICStocktakeData.PostStatus = "C" Then
      btnPendingVariance.ShowStatusHint("Stcktake already Counted - Ready to Post")
    Else
      Try
        ICStocktakeData.Counted
        btnPendingVariance.ShowStatusHint("Pending Variance Counted - Stocktake Marked as Counted")
      Catch e
        btnPendingVariance.ShowErrorHint("ERROR: " & e.message)
      End Try
    End If
    PostStockTake
  End If
  
End Sub

Sub Okay_Click
  Dim Bin as string
  Dim Filter as String
  Dim StkDetails as String
  Dim VanCount as Boolean
  VanCount = False
  
  Dim ICCountdata as object
  ICCountdata = CreateObject("Accredo.ICStocktakeCountData")
  
  If eExisting.value = True Then
    
    '#################### EXISTING ###################
    
    
    Bin = ""
    If StktakeNo.text = "" Then
      StktakeNo.ShowErrorHint("Select a StockTake")
      Exit Sub
    End If
    '      Dim Form as Object
    '      Form = CreateObject("Accredo.ScriptedForm")
    '      Form.Caption = "Select Bin Location"
    '      Form.inputbox("Bin","Bin Location (Can be Blank)")
    '      If Form.Execute Then
    '        Bin = Form.GetValue("Bin")
    '      end if
    '    ICStocktakeData.DocumentID = StktakeNo 'Stocktake Dropdown"
    '    MSGBOX(eExisting.value&" "&StktakeNo.value)
    If ICStocktakeData.Findexact(StktakeNo.text) Then
      OpenICStocktakeForm(StktakeNo.text, ICStocktakeData.LocationCode, ebinloc.text)
    Else
      Throw "Logic Error Unable to Find Stocktake"
    End If
  Else
    
    '####################### NEW #####################
    
    If eDetail.text = "" Then
      eDetail.ShowErrorHint("Reference Cannot be Blank")
      Exit Sub
    End If
    If eLocation.text = "" Then
      eLocation.ShowErrorHint("Location Cannot be Blank")
      Exit Sub
    End If
    StkPeriod = CurrentPeriod("IC")
    BIN = eBinLoc.text
    
    If left(eLocation.text,2) = "HV" or left(eLocation.text,2) = "CV" or left(eLocation.text,2) = "WV" Then
      Filter = ""
      VanCount = True
      StkDetails = "Location " & eLocation.text & " For Period " & StkPeriod
    Else
      If eBinLoc.Text = "" Then
        eBinLoc.ShowErrorHint("Bin Location Required")
        Abort("",True)
      End If
      Filter = "(BinLocation = """ & Bin & """)" & " or ( Z_BinLocation2 = """ & Bin & """)"
      StkDetails = "Location " & eLocation.text & " For Period " & StkPeriod & " Bin " & eBinloc.text
    End If
    
    
    '    MSGBOX(Filter)
    '       Abort
    Dim Form1 as Object
    Form1 = CreateObject("Accredo.ICGenerateStocktakeForm")
    Form1.Location = eLocation.text
    
    Form1.Details = StkDetails
    If VanCount = True Then
      Form1.CountType = "Additive"
      Form1.GenerateCounts = True
      Form1.IncludeNilQuantity = False
    Else
      Form1.StocktakeFilterSort.Filter = Filter
      Form1.CountType = "Additive"
      Form1.GenerateCounts = False
      Form1.IncludeNilQuantity = True
    End If
    Form1.Reference = eDetail.text
    
    '   Form1.GenerateCounts = False
    Form1.Date = eDate.Value
    Form1.Period = periodfordate(eDate.Value)
    Try
      Form1.Run
      
      '[CAN'T CATCH IF THERE'S NOTHING TO GENERATE]
    Catch e
      msgbox("ERROR: " & e.message)
    End Try
    
    Env = createobject("Accredo.Environment")
    FormAct = Env.GetActiveObject
    
    If FormAct.ClassName = "ICStocktakeEditForm" Then
      FormAct.Close
    End If
    
    Env = nothing
    
    Dim StkData as Object
    StkData = CreateObject("Accredo.ICStocktakeData")
    StkData.indexname = "Document"
    '    IF User.LoginUserName = "ACCREDO" Then MSGBOX("Stk = " & StkDetails)
    Found = False
    
    StkData.Last
    Do Until StkData.BOF
      '      IF User.LoginUserName = "ACCREDO" Then MSGBOX("StkF = " & StkDetails & " - " & StkData.Details)
      If StkData.Details = StkDetails Then
        '        IF User.LoginUserName = "ACCREDO" Then MSGBOX("StkFound = " & StkDetails & " - " & StkData.Details)
        Found = True
        Exit Do
      End If
      StkData.Prev
    Loop
    If VanCount = True Then
      Found = False
      RefreshStocktakeList
      StktakeNo.text = StkData.DocumentID
      eExisting.checked = True
    End If
    If Found = TRUE Then
      
      StkData.Edit
      StkData.Z_BinLocation = Bin
      StkData.Save
      
      Dim StkProd as Object
      StkProd = StkData.Product
      Dim StkCount as Object
      StkCount = CreateObject("Accredo.ICStocktakeCountData")
      StkCount.indexname = "COUNT"
      
      Dim CountLine as Object
      CountLine = StkCount.Line
      
      Dim ICQty as object
      ICQty = opentable("ICQty")
      ICQty.Indexname = "LocationProduct"
      
      NewCount = True
      Cnt = 0
      StkProd.First
      '      iF User.LoginUserName = "ACCREDO" Then MSGBOX("Van Flag = " & Vancount & " - " & eLocation.text)
      Do Until StkProd.EOF
        
        If ICQTY.Findexact(eLocation.text,StkProd.ProductCode) Then
          '          iF User.LoginUserName = "ACCREDO" and cnt < 5 Then MSGBOX("Van Flag = " & Vancount & " - " & eLocation.text & " - " & StkProd.ProductCode & " - " & ICQTY.BinLocation)
          cnt = cnt + 1
          If ICQTY.BinLocation <> "" or VanCount = True Then
            If NewCount = True Then
              NewCount = False
              StkCount.Insertcount(StkData.DocumentId)
              StkCount.Custom1 = "Location " & eLocation.text & " Bin = " & ICQty.Binlocation
              '             Countmsg = countmsg & StkCount.Custom1 & CRLF
              StkCount.BranchCode = ICQTY.BranchCode
              StkCount.DepartmentCode = ICQTY.DepartmentCode
              '              StkCount.DocumentType = "N"
              StkCount.Details = StkData.Details & " Bin = " & ICQty.BinLocation
              '              StkCount.Z_BinCode = ICQty.BinLocation
              StkCount.CountType = "A"
              StkCount.SAVE
            End If
            If not StkCount.Editing then StkCount.Edit
            Countline.Append
            Countline.ProductCode = StkProd.ProductCode
            '           CountLine.BinLocation = ICQty.BinLocation
            CountLine.Z_BinCode = ICQty.BinLocation
            CountLine.Z_BinCode2 = ICQty.Z_Binlocation2
            
          End If
        End If
        
        StkProd.Next
      Loop
      If StkCount.Editing then StkCount.Save
      If VanCount = False Then
        NewCount = True
        StkProd.First
        '      MSGBOX(eLocation.text& " - " & StkProd.ProductCode )
        BLen = len(Bin)
        '      Msgbox(Bin & " - " & Blen & " - " & eLocation.text)
        Do Until StkProd.EOF
          
          If ICQTY.Findexact(eLocation.text,StkProd.ProductCode) Then
            '          IF StkProd.ProductCode = "AROTAILHOSE10MM" Then MSGBOX(eLocation.text& " - " & StkProd.ProductCode & " Bin2 = "  & ICQTY.Z_Binlocation2 )
            If (eLocation.text = "HAM" and ICQTY.Z_Binlocation2 <> "" and (ICQTY.Z_Binlocation2 <> Bin or ICQTY.Binlocation <> Bin )) _
            or (eLocation.text <> "HAM" and ICQTY.Z_Binlocation2 <> "" and Left(ICQTY.Z_Binlocation2,Blen) <> Left(Bin,Blen) ) Then
            '            MSGBOX(eLocation.text& " - " & StkProd.ProductCode )
            If NewCount = True Then
              NewCount = False
              StkCount.Insertcount(StkData.DocumentId)
              StkCount.Custom1 = "Location " & eLocation.text & " Bin Location 2 "
              StkCount.BranchCode = ICQTY.BranchCode
              StkCount.DepartmentCode = ICQTY.DepartmentCode
              StkCount.Details = StkData.Details & " Bin Location 2"
              StkCount.CountType = "A"
              StkCount.Save
              
            End If
            If not StkCount.Editing then StkCount.Edit
            Countline.Append
            Countline.ProductCode = StkProd.ProductCode
            CountLine.BinLocation = ICQty.BinLocation
            '            CountLine.BinLocation = ICQty.Z_BinLocation2
            CountLine.Z_BinCode = ICQty.Z_BinLocation2
            '          MSGBOX(eLocation.text & " - " & StkProd.ProductCode & " - " & CountLine.BinLocation & " - " & CountLine.Z_BinCode)
            
            
            
          End If
        End If
        
        StkProd.Next
      Loop
      
      
      If StkCount.Editing then StkCount.Save
    End If
  End If
  Try
    eExisting_Clicked
    RefreshStocktakeList
    
    
    '[AUTOOPEN FIRST COUNT]
    If AutoOpenCount = True Then
      CTable = ExecuteSQL("Select DocumentID, CountID, Details, CountStatus FROM ICCNTHD WHERE DocumentID = :STKID ", val(StktakeNo.Text))
      CTable.First
      '            IF User.LoginUserName = "ACCREDO" Then Browsedataset(CTable)
      If ICStocktakeData.FindExact(CTable.DocumentID) Then
        cs = instrRev(CTable.Details,"Bin = ")
        BL = ""
        '              IF User.LoginUserName = "ACCREDO" Then msgbox(CS & " - " & CTable.Details)
        If cs <> 0 Then
          BL = mid(CTable.Details,cs + 6,len(CTable.Details))
        End If
        Try
          EditCount(CTable.DocumentID,ICStocktakeData.LocationCode,BL,CTable.CountID,True)
        Catch e
          msgbox("AutoOpen Error: " & e.message & "|" & e.sourcepos)
        End Try
      End If
    End If
    '[--------------------]
    
    
  Catch e
    If User.LoginUserName = "ACCREDO" then msgbox("Accredo User Only Message: " & e.message)
  End Try
  
  
  '    End If
End If


'' Print BEFORE Report
Locn = User.DefaultLocationCode
If Left(Locn,1) = "W" Then
  Dim Form1 as Object
  Form1 = CreateObject("Accredo.ICProductReport")
  Form1.Layout = "Inventory Levels"
  Form1.Destination = "Screen"
  Form1.Location = eLocation.text
  Form1.ReportFilterSort.Filter = "((BinLocation=""" & eBinLoc.text & """) Or (Z_BinLocation2=""" & eBinLoc.text & """)) And (ClosingPeriodToDate<>0.00)"
  ' MSGBOX(
  Form1.Run
  Form1 = Nothing
End If



