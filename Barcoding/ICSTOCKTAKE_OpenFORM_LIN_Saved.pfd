End Sub


Sub Print_Single_Count
'  MSGBOX("Stk No = " & StktakeNo.Text & " Table Value = " & tblICSTKHD.DocumentID)
Dim ICStocktakeData as Object
ICStocktakeData = CreateObject("Accredo.ICStocktakeData")
ICStocktakeData.indexname = "Document"
If ICStocktakeData.FindExact(StktakeNo.Text) Then
  WCntId = Val(StktakeNo.Text)
  '    MSGBOX("Start Sql")
  TblCount = ExecuteSQl("SELECT ICCNTHD.CountID " & _
    " FROM ICCNTHD " & _
    " WHERE (ICCNTHD.DocumentID = :CntId) " , WCntId )
  '    Msgbox("Finish SQL")
  Dim CountString as String
  Dim CountFirst as String
  TblCount.First
  CountFirst = FormatNumber(TblCount.CountId)
  
  TblCount.First
  CountFirst = FormatNumber(TblCount.CountId)
  Do Until TblCount.EOF
    If CountString = "" Then
      CountString = FormatNumber(TblCount.CountId)
    Else
      CountString = CountString & "," & FormatNumber(TblCount.CountId)
    End If
    TblCount.Next
  Loop
  
  Dim FormPS as Object
  FormPS = CreateObject("Accredo.ScriptedForm")
  Dim SelCount as String
  FormPS.Caption = "Select Count"
  FormPS.Inputlist("CountId", "CountID", CountFirst,CountString)
  FormPS.SetValue("CountId",CountFirst)
  Do
    If FormPS.Execute Then
      SelCount = FormPS.GetValue("CountId")
      If SelCount <> "" Then Exit Do
    Else
      Abort("Cancelled by User")
    End If
  Loop
  Dim MyPrinter as String
  Dim SReport as Object
  SReport = CreateObject("Accredo.UTCustomReport")
  SReport.ReportFileName = "Barcoding\LIN_Count_Sheets_One_SingleBin.pfd"
  If Left(Locn,1) = "H" Then
    MyPrinter = "HP LaserJet Pro MFP M127-M128 PCLmS"
  ElseIf Left(Locn,1) = "C" then
    MyPrinter = "CHCH_HP M570"
  ElseIf Left(Locn,1) = "W" then
    MyPrinter = "HP Wellington"
  ElseIf Left(Locn,1) = "T" then
    MyPrinter = "OUTTGA"
  ElseIf Company.CompanyName = "DBNZ Coatings Ltd" Then
    MyPrinter = "DBA_HP_M201"
  Else
    MyPrinter = ""
  End If
  If User.LoginUserName = "ACCREDO" Then
    SReport.Destination = "SCREEN"
    '      MSGBOX("Location = " & LOCN & " Printer= " & MYPrinter)
  Else
    SReport.Printer.PrinterName = MyPrinter
  End If
  '    SReport.Destination = "SCREEN"
  SReport.Run(val(StktakeNo.text),val(SelCount))
End If
End Sub

