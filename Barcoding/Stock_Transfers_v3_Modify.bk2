  <![CDATA['Imports "API\CheckPreDefined.pfs"
'Imports "API\getAppSetting.pfs"

Dim TransferListForm as Object
If Company.CompanyMenuCode = "LPSA" or Company.CompanyMenuName = "Linkup Play (Auckland) Ltd" Then
  DefaultSourceLocation = "AKL"
Else
  DefaultSourceLocation = "DBNZ"
End If
Dim MyPrinter as String

Dim _TransferList as Object

Public Property Let P_TransferList(Value as Object)
  _TransferList = Value
End Property

StaffScan = False
CarierReqd = False
CarrierScan = False
ForceClose = False
DocID = 0
OpenExisting = False
InsertMode = False
LoadMode = False
EditMode = False
ReceiptMode = False
Returnprod = False

SourceLocation = False
DestinationLocation = False
Dim AutoDest as String

Dim Builder as Object
Builder = CreateObject("Accredo.MemoryTableBuilder")
Dim NewField as Object
NewField = Builder.AddField("ProductCode", "IC Product Code")
NewField = Builder.AddField("Description", "Description")
NewField = Builder.AddField("Expected","Quantity")
NewField = Builder.AddField("Dispatch","Quantity")
NewField = Builder.AddField("Difference","Quantity")
Difftable = Builder.CreateTable
NewField = Nothing
Builder = Nothing

Dim Directory as object
Directory = Createobject("Accredo.Directory")

Dim ICProdData as object
ICProdData = createobject("Accredo.ICProductData")
ICProdData.Indexname = "Product"

Dim ICPROD as OBJECT
ICPROD = Opentable("ICPROD")
ICPROD.indexname = "Product"

Dim ICBAR as OBJECT
ICBAR = Opentable("ICBAR")
ICBAR.indexname = "Barcode"

Dim ICQTY as Object
ICQTY = opentable("ICQTY")
ICQTY.IndexName = "ProductLocation"


Dim ICLOCN as OBJECT
ICLOCN = Opentable("ICLOCN")
ICLOCN.indexname = "ActiveLocation"

Dim TOLOCN as OBJECT
TOLOCN = Opentable("ICLOCN")
TOLOCN.indexname = "Location"

Dim ICTFER as Object
ICTFER = createobject("Accredo.ICTransferData")
ICTFER.IndexName = "Document"

Dim IsDG as Boolean
IsDG = False


Sub Status
  If Not StaffScan Then
    eStatus.Text = "Scan Staff Reference"
  ElseIf eCarrierCode.Text = "" and CarierReqd Then
    eStatus.Text = "Scan Carrier Bar Code"
  Else
    eStatus.Text = "Scan Product"
  End If
End Sub

Sub btnInitSwitch_Click
  
  preSource = pnlInitSource.Text
  pnlInitSource.Text = pnlInitDest.Text
  pnlInitDest.Text = preSource
  
End Sub


Sub Reset
  OpenExisting = False
  SourceLocation = false
  DestinationLocation = False
  StaffScan = False
  eDocID.Value = 0
  tblTransfers.Empty
  eSourceLocation.Text = ""
  eDestinationLocation.Text = ""
  btnComplete.Enabled = True
  eSourceLocation.Enabled = SourceLocation
  eDestinationLocation.Enabled = DestinationLocation
  eMode.Text = ""
  Status
End Sub


'Sub btnAssignBarcode_Click
'
'  eBarcode.SetFocus
'  AssignBarcodeForm = CreateCustomForm("BinLocation_Quick_Input_EAN128.pfd")
'
'
'End Sub




Sub Close
  Self.Close
  Try
    _TransferList.RefreshGrid
  Catch
  End Try
End Sub

Sub ConfirmClose
  If ForceClose = False Then
    If Not inputquery("Confirm Close") Then
      abort("",True)
    End If
  End If
  Try
    _TransferList.RefreshGrid
  Catch
  End Try
  
End Sub

Sub ProductDetails
  If ICPROD.FIndexact(tblTransfers.ProductCode) Then
    eProductCode.Text = ICPROD.ProductCode
    eProductName.Text = ICPROD.Description
    If ApplicationSetting( "IC\ValuationBasis") = "L" Then
      eCostPrice.Text = formatNumber(ICPROD.LatestCost,"Amount")
    ElseIf ApplicationSetting( "IC\ValuationBasis") = "A" Then
      eCostPrice.Value = ICPROD.AverageCost
    ElseIf ApplicationSetting( "IC\ValuationBasis") = "S" Then
      eCostPrice.Value = ICPROD.StandardCost
    End If
  End If
  ePicked.Value = tblTransfers.Quantity
  eExpected.Value = tblTransfers.QuantityExpected
  eWeight.value = ICProd.Weight
  eVolume.value = ICProd.Volume
End Sub

Sub pnlInitBtnOK_Click
  
  If pnlInitSource.Text = "" Then
    pnlInitSource.ShowErrorHint("Please Enter Source Location")
    Abort("",True)
  ElseIf pnlInitDest.Text = "" then
    pnlInitDest.ShowErrorHint("Please Enter Destination Location")
    Abort("",True)
  End If
  
  If ICLOCN.Findexact(False,pnlInitSource.Text) Then
    If ICLOCN.LocationCode <> pnlInitDest.Text Then
      eSourceLocation.Text = ICLOCN.LocationCode
      SourceLocation = True
      eSourceLocation.Enabled = SourceLocation
    Else
      PnlInitSource.ShowErrorHint("Source Location Cannot be Same as Destination")
      Abort("",True)
    End If
  Else
    PnlInitSource.ShowErrorHint("Location Not Found")
    Abort("",True)
  End If
  
  If ICLOCN.Findexact(False,pnlInitDest.Text) Then
    If ICLOCN.LocationCode <> pnlInitSource.Text Then
      eDestinationLocation.Text = ICLOCN.LocationCode
      DestinationLocation = True
      eDestinationLocation.Enabled = DestinationLocation
    Else
      PnlInitDest.ShowErrorHint("Destination Location Cannot be Same as Source")
      Abort("",True)
    End If
  Else
    PnlInitDest.ShowErrorHint("Location Not Found")
    Abort("",True)
  End If
  
  pnlInit.Visible = False
  eBarcode.SetFocus
End Sub

Sub Location_Transfer
  'IF User.LoginUserName = "ACCREDO" then Msgbox(Autodest)
  ProdTable = ExecuteSQl("SELECT ICQTY.ProductCode " & _
    " ,ICPROD.Description " & _
    " ,ICPROD.BarCode " & _
    " ,ICQTY.LocationCode " & _
    " ,ICQTY.QuantityInStock " & _
    " ,ICQTY.QuantityOnBackOrder " & _
    " ,ICQTY.QuantityAvailable " & _
    " ,ICQTY.MinimumQuantity " & _
    " ,ICQTY.QuantityInTransit " & _
    " ,ICQTY.QuantityOnOrder " & _
    " ,ICQTY.QuantityRecReorder " & _
    " ,HAMQty.QuantityInStock as HamQty " & _
    " ,HamQty.QuantityAvailable as HamAvail " & _
    "FROM ICQty " & _
    " LEFT JOIN ICProd ON ICQty.ProductCode=ICPROD.ProductCode " & _
    " Left JOIN ICQTY HamQTY ON ICQTY.ProductCode=HamQty.ProductCode and HamQTY.LocationCode = 'DBNZ' " & _
    "WHERE ICQTY.LocationCode = :Locn " & _
    " and ICQTY.QuantityRecReorder > 0 " & _
    " and ICPROD.Discontinued = False " & _
    " and ICPROD.Inactive = False " & _
    " and ICPROD.NonDiminishing = False " & _
    " Order By ICPROD.ProductCode " , AutoDest)
  
  '                        "   and (ICPROD.CreditorCode <> 'DBA' AND ICPROD.CreditorCode <> 'NZCOUR' AND ICPROD.CreditorCode <> 'PBTC' " & _
    ''                        "   and ICPROD.CreditorCode <> 'VALS' AND ICPROD.CreditorCode <> 'PAINTS' ) " & _
    
  '                        "   and (ICQTY.QuantityInStock + ICQTY.QuantityOnOrder + ICQTY.QuantityInTransit < ICQTY.QuantityRecReorder ) " & _
    '                         "   AND ICQTY.MinimumQuantity > 0) " & _
    
  eSourceLocation.text = "DBNZ"
  eDestinationLocation.text = AutoDest
  eReference.text = User.LoginUserCode
  eTransferDate.value = Date
  eStatus.text = "Scan Staff Reference"
  tblTransfers.Empty
  ProdTable.First
  'IF User.LoginUserName = "ACCREDO" then Browsedataset(Prodtable)
  Do until ProdTable.Eof
    If ICQTY.FindExact(ProdTable.ProductCode,"DBNZ") Then
      '        IF ICQTY.QuantityAvailable > 0 Then
      '
      QTYREQD = (Prodtable.MinimumQuantity + ICQTY.QuantityOnBackOrder ) - Prodtable.QuantityAvailable - Prodtable.QuantityonOrder - Prodtable.QuantityInTransit
      '
      tblTransfers.Append
      tblTransfers.ProductCode = ProdTable.ProductCode
      tblTransfers.Description = Prodtable.description
      tblTransfers.BarCode = Prodtable.BarCode
      tblTransfers.Quantity = ProdTable.QuantityRecReorder 'QtyReqd
      tblTransfers.QtyAvailable = Prodtable.HamQty
      Lgth = 0
      Lgth=LEN(ICQTY.BinLocation)
      If lgth = 1 Then
        tblTransfers.BinKey = "00" & ICQTY.BinLocation
      ElseIf lgth = 2 Then
        tblTransfers.BinKey = "0" & ICQTY.BinLocation
      Else
        tblTransfers.BinKey = ICQTY.BinLocation
      End If
      tblTransfers.Save
      
    End If
    ProdTable.Next
  Loop
  InsertMode = True
  '  MSGBOX("Auto Transfer from Hamilton to " & AutoDest & " Completed")
  
End Sub

Sub OnLoad
  
  eTransferDate.Value = Systemdate
  Dim ICQTY as Object
  ICQTY = OpenTable("ICQTY")
  ICQTY.IndexName = "LocationProduct"
  Autodest = ""
  
  If ScriptArgs.Count > 1 Then
    AutoDest = ScriptArgs[3]
    If AutoDest = "WGTN" or AutoDest = "TAS" Then
      Location_Transfer
    Else
      DocID = ScriptArgs[1]
      
      If ScriptArgs.Count > 2 Then
        If ScriptArgs[2] = "EDIT" Then
          EditMode = True
          LoadMode = False
          ReceiptMode = False
          eMode.Text = "EDIT MODE"
          tblTransfers.Fields.item("Adjustment").Visible = False
          btnComplete.Enabled = False
          
        End If
        If ScriptArgs[2] = "LOADPALLET" Then
          eMode.Text = "LOAD PALLET MODE"
          If User.LoginUserName = "ACCREDO" Then MSGBOX("Load Pallet")
          LoadMode = True
          EditMode = False
          ReceiptMode = False
          tblTransfers.Fields.item("Adjustment").Visible = False
          btnComplete.Caption = "Dispatch"
          btnSave.Enabled = False
          btnPrint.Enabled = False
        End If
        If ScriptArgs[2] = "RECEIPT" Then
          ReceiptMode = True
          EditMode = False
          LoadMode = False
          eMode.Text = "RECEIPT MODE"
          btnSave.Enabled = False
          btnPrint.Enabled = False
        End If
      End If
      
      If ICTFER.FindExact(DocID) Then
        OpenExisting = True
        tblTransfers.AllowInsertDelete = True
        If NOT EditMode Then
          tblTransfers.Active = False
          '        tblTransfers.AddField("QuantityExpected","Quantity")
          tblTransfers.Active = True
        End If
        eSourceLocation.Text = ICTFER.SourceLocationCode
        eDestinationLocation.Text = ICTFER.DestinationLocationCode
        eCarriercode.text = ICTFER.Z_ShipperCode
        If ICTfer.TransitLocationCode <> "" and ICTFER.Z_ShipperCode = "" Then
          CarierReqd = True
        End If
        SourceLocation = True
        DestinationLocation = True
        eReference.Text = ICTFER.Reference
        Status
        
        LN = ICTFER.Line
        
        Ln.First
        
        tblTransfers.IndexName = "Product"
        Do Until LN.EOF
          tblTransfers.Append
          tblTransfers.ProductCode = LN.ProductCode
          tblTransfers.Description = LN.Description
          If EditMode Then
            tblTransfers.Quantity = LN.QuantityDispatched
          Else
            tblTransfers.QuantityExpected = LN.QuantityDispatched
            tblTransfers.Adjustment = LN.QuantityDispatched
          End If
          tblTransfers.QtyOutstanding = LN.QuantityDispatched
          If ICProdData.FindExact(LN.ProductCode) Then
            ICProdData.Barcodes.First
            If ICProdData.Barcodes.Barcode <> "" Then
              tblTransfers.Barcode = ICProdData.Barcodes.Barcode
            End If
          End If
          tblTransfers.LineID = LN.LineID
          If ICQTY.Findexact(eSourceLocation.text,LN.ProductCode) Then
            Lgth = 0
            Lgth=LEN(ICQTY.BinLocation)
            tblTransfers.BinLocation = ICQTY.BinLocation
            tblTransfers.BinLocation2 = ICQTY.Z_BinLocation2
            tblTransfers.QtyAvailable = ICQTY.QuantityAvailable
            If lgth = 1 Then
              tblTransfers.BinKey = "00" & ICQTY.BinLocation
            ElseIf lgth = 2 Then
              tblTransfers.BinKey = "0" & ICQTY.BinLocation
            Else
              tblTransfers.BinKey = ICQTY.BinLocation
            End If
          End If
          tblTransfers.Save
          tblTransfers.Refresh
          LN.Next
        Loop
        tblTransfers.First
        ProductDetails
      End If
      
      tblTransfers.Fields.Item("ProductCode").Readonly = True
      tblTransfers.Fields.Item("Quantity").Readonly = True
    End If
  Else
    'Insert Mode
    InsertMode = True
    SourceLocation = False
    DestinationLocation = False
    Dest = IIF(User.Defaultlocationcode <> DefaultSourceLocation,User.DefaultLocationCode,"")
    If User.DefaultLocationCode <> "" Then
      pnlInitDest.Text = Dest
      ICL = opentable("ICLOCN")
      ICL.IndexName = "Location"
      ICL.First
      Do Until ICL.EOF
        If ICL.LocationCode <> pnlInitDest.Text Then
          Source = ICL.LocationCode
          Exit Do
        End If
        ICL.Next
      Loop
      pnlInitSource.Text = DefaultSourceLocation
    Else
      msgbox("Please set User's Default Location Code")
    End If
    pnlInit.Top = 168
    pnlInit.Left = 307
    pnlInit.Visible = True
    pnlInitSource.SetFocus
    Reset
    Status
    eMode.Text = "INSERT MODE"
    btnComplete.Enabled = False
    tblTransfers.Fields.Item("ProductCode").Readonly = False
    tblTransfers.Fields.Item("Quantity").Readonly = False
  End If
  
  '  grpCarrier.Visible = getAppSetting("ST_UseCarrier")
  tblTransfers.IndexName = "BinKey"
  tblTransfers.Refresh
  tblTransfers.first
End Sub


Sub Prev_Date
  eTransferDate.Value = eTransferDate.Value - 1
  eBarcode.SetFocus
End Sub

Sub Next_Date
  eTransferDate.Value = eTransferDate.Value + 1
  eBarcode.SetFocus
End Sub


Sub ProductScanCheck
  
  tblTransfers.Fields.Item("ProductCode").Readonly = False
  tblTransfers.Fields.Item("Quantity").Readonly = False
  CPD_Weight = 1
  Dim CPD_ProdCode as String
  If ICPROD.FindExact(eBarcode.Text) Then
    CPD_ProdCode = ICProd.ProductCode
  Else
    Dim ICBar as Object
    ICBar = Opentable("ICBAR")
    ICBAR.indexname = "Barcode"
    If ICBar.FindExact(eBarcode.Text) Then
      CPD_ProdCode = ICBar.ProductCode
    End If
    '    CheckPreDefined(eBarcode.Text,tblEAN128)
  End If
  Qty = CPD_Weight
  tblTransfers.indexname = "Product"
  If CPD_ProdCode <> "" Then
    If ICProd.FindExact(CPD_ProdCode) Then
      If ICPROD.NonDiminishing <> True Then
        If Not ICPROD.Inactive Then
          If tblTransfers.Findexact(CPD_ProdCode) Then
            tblTransfers.Edit
            tblTransfers.Quantity = (tblTransfers.Quantity + Qty)
            tblTransfers.QtyOutstanding = tblTransfers.QuantityExpected - tblTransfers.Quantity
            If ReceiptMode Then
              tblTransfers.Adjustment = tblTransfers.QuantityExpected - tbltransfers.Quantity
            End If
            tblTransfers.Save
            
            ProductDetails
          Else
            If NOT EditMode Then
              If OpenExisting = True Then
                If NOT InputQuery("Product " & CPD_ProdCode & " (" & ICProd.Description & ") was NOT found on the transfer!" & chr(13) & _
                "Would you like to add this product to the transfer or cancel scan?") then
                tblTransfers.Fields.Item("ProductCode").Readonly = True
                tblTransfers.Fields.Item("Quantity").Readonly = True
                Exit Sub
              End If
            End If
          End If
          
          tblTransfers.AllowInsertDelete = True
          tblTransfers.Append
          tblTransfers.ProductCode = CPD_ProdCode
          tblTransfers.Description = ICPROD.Description
          tblTransfers.Quantity = (tblTransfers.Quantity + Qty)
          
          tblTransfers.QtyOutstanding = tblTransfers.QuantityExpected - tblTransfers.Quantity
          If ICQTY.Findexact(ICProd.ProductCode,eSourceLocation.Text) Then
            tblTransfers.QtyAvailable = ICQty.Quantityinstock
            '                Lgth = 0
            '                Lgth=LEN(ICQTY.BinLocation)
            '                If lgth = 1 Then
            '                  tblTransfers.BinKey = "00" & ProdTable.BinLocation
            '                ElseIf lgth = 2 Then
            '                  tblTransfers.BinKey = "0" & ProdTable.BinLocation
            '                Else
            '                  tblTransfers.BinKey = ProdTable.BinLocation
            '                End If
          End If
          '            MSGBOX("out = " & tblTransfers.QtyOutstanding & " - "  & tblTransfers.QuantityExpected & " - "  & tblTransfers.Quantity)
          tblTransfers.Save
          'tblTransfers.AllowInsertDelete = False
          
          ProductDetails
        End If
        tblTransfers.refresh
        
      Else
        eBarcode.Showerrorhint("Product is Inactive")
      End If
      
      eProductCode.Text = CPD_ProdCode
      eProductName.Text = ICPROD.Description
      
    Else
      eBarcode.Showerrorhint("Product is No Diminishing")
    End If
  End If
Else
  '    MSGBOX("Barcode not found - " & CPD_ProdCode)
  eBarcode.Showerrorhint("Barcode not found")
  If NOT InsertMode Then
    tblTransfers.Fields.Item("ProductCode").Readonly = True
    tblTransfers.Fields.Item("Quantity").Readonly = True
  End If
  eBarcode.SetFocus
End If

tblTransfers.IndexName = "BinKey"
tblTransfers.Refresh
tblTransfers.First

'  MSGBOX("Error Hint " & CPD_ProdCode)
'  eBarcode.SetFocus
'  IF NOT InsertMode then
tblTransfers.Fields.Item("ProductCode").Readonly = True
tblTransfers.Fields.Item("Quantity").Readonly = True
'  End IF
End Sub

Sub Amend_Qty

tblTransfers.QtyOutstanding = tblTransfers.QuantityExpected - tblTransfers.Quantity
'  MSGBOX("out = " & tblTransfers.QtyOutstanding & " - "  & tblTransfers.QuantityExpected & " - "  & tblTransfers.Quantity)

End Sub

Sub AddProduct

If ICProd.FindExact(eProduct.Text) AND InsertMode Then
  tblTransfers.ProductCode = ICProd.ProductCode
  tblTransfers.Description = ICProd.Description
  If ICQTY.Findexact(ICProd.ProductCode,eSourceLocation.Text) Then
    tblTransfers.QtyAvailable = ICQty.Quantityinstock
    Lgth = 0
    Lgth=LEN(ICQTY.BinLocation)
    If lgth = 1 Then
      tblTransfers.BinKey = "00" & ICQty.BinLocation
    ElseIf lgth = 2 Then
      tblTransfers.BinKey = "0" & ICQty.BinLocation
    Else
      tblTransfers.BinKey = ICQty.BinLocation
    End If
  End If
End If


End Sub

Sub Move_Next
tblTransfers.Next
ProductDetails
eBarcode.SetFocus

End Sub

Sub Move_Prev
tblTransfers.Prev
ProductDetails
eBarcode.SetFocus
End Sub

Sub Save(PrintTransfer as Boolean)
Dim TransfData as Object
TransfData = CreateObject("Accredo.ICTransferData")
If DocID = 0 Then
  TransfData.InsertTransfer
Else
  If TransfData.FindExact(DocID) Then
    TransfData.Edit
  End If
End If
ToLocn.FindExact(eDestinationLocation.Text)
ICLOCN.Findexact(False,eSourceLocation.Text)
TransfData.DocumentDate = eTransferDate.value
TransfData.ReceiptDate = eTransferDate.value
TransfData.PeriodID = PeriodforDate(TransfData.DocumentDate)
TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
TransfData.SourceLocationCode = eSourceLocation.Text
TransfData.DestinationLocationCode = eDestinationLocation.Text
If Autodest <> "" Then TransfData.Comment = "Auto Transfer for " & autodest
If ToLocn.Z_Van = True or ICLocn.Z_Van = True Then
  TransfData.TransitLocationCode = ""
Else
  TransfData.TransitLocationCode = "TRANSIT" 'getAppSetting("ST_DefaultTransitLoc")
End If

TransfData.Reference = eReference.Text
'  IF getAppSetting("ST_UseCarrier") Then TransfData.Z_ShipperCode = eCarrierCode.Text
TransfData.Z_ShipperCode = eCarrierCode.Text
tblTransfers.First
TransfData.Line.Empty

Do until tblTransfers.Eof
  TransfData.Line.Append
  TransfData.Line.ProductCode = tblTransfers.ProductCode
  If NOT EditMode Then
    If tblTransfers.Quantity = 0 Then
      TransfData.Line.QuantityDispatched = tblTransfers.QuantityExpected
    Else
      TransfData.Line.QuantityDispatched = tblTransfers.Quantity
    End If
  Else
    TransfData.Line.QuantityDispatched = tblTransfers.Quantity
  End If
  TransfData.Line.Z_Sort_Bin = tblTransfers.BinKey
  TransfData.Line.Save
  tblTransfers.Next
Loop
TransfData.Save

Dim MyPrinter as String
Dim Locn as String
Dim PrintTransF as Object
Dim PrintTransS as Object

'  IF PrintTransfer Then
'IF User.LoginUserName = "ACCREDO" Then MSGBOX(eDestinationLocation.text)
If ToLocn.Z_Van = False Then
  Locn = eDestinationLocation.text 'eSourceLocation.text 'User.DefaultLocationCode
  If Left(Locn,1) = "D" Then
    MyPrinter = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
  ElseIf Left(Locn,1) = "W" then
    MyPrinter = "Toshiba Wellington" '"HP Wellington B&W"
  Else
    MyPrinter = "SCREEN"
  End If
  PrintTransf = TransfData.Print
  PrintTransf.ReportFileName = "ICTransfer1_BarcodeEAN.pfd"'"ICTransfer_Modify.pfd"
  If User.LoginUserName = "ACCREDO" Then
    PrintTransf.Destination = "SCREEN"
    MSGBOX("Prt Trf " & MyPrinter)
  Else
    PrintTransf.Destination = "Printer"
    PrintTransf.Printer.PrinterName = MyPrinter
  End If
  PrintTransf.Run
  
End If
Locn = eSourceLocation.text 'User.DefaultLocationCode
If Left(Locn,1) = "D" Then
  '    MyPrinter = "HP LaserJet Pro MFP M127-M128 PCLmS"
  MyPrinter = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
  '  ElseIf Left(Locn,1) = "C" then
  '    MyPrinter = "CHCH_HP M570"
ElseIf Left(Locn,1) = "W" then
  MyPrinter = "Toshiba Wellington" '"HP Wellington B&W"
Else
  MyPrinter = ""
End If

PrintTransS = TransfData.Print
PrintTransS.ReportFileName = "ICTransfer1_BarcodeEAN.pfd"'"ICTransfer_Modify.pfd"
If User.LoginUserName = "ACCREDO" Then
  PrintTransS.Destination = "SCREEN"
  MSGBOX("+++ " & MyPrinter)
Else
  PrintTransS.Destination = "Printer"
  PrintTransS.Printer.PrinterName = MyPrinter
End If
PrintTransS.Run


Status
ForceClose = True
Try
  _TransferList.RefreshGrid
Catch e
  
End Try

Self.close
End Sub

