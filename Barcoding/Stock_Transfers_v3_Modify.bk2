Sub CheckForDG(ByVal ProdCode as Object)
If ICProd.FindExact(ProdCode) Then
  IsDG = ICProd.Z_DG_Product
End If
End Sub

Sub SaveTransfer(Byref Post as Boolean)
Dim TransfData as Object
TransfData = CreateObject("Accredo.ICTransferData")
If DocID = 0 Then
  TransfData.InsertTransfer
Else
  If TransfData.FindExact(DocID) Then
    TransfData.Edit
  End If
End If

If NOT ReceiptMode Then
  
  TransfData.DocumentDate = eTransferDate.value
  TransfData.ReceiptDate = eTransferDate.value
  TransfData.PeriodID = PeriodforDate(TransfData.DocumentDate)
  TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
  TransfData.SourceLocationCode = eSourceLocation.Text
  TransfData.DestinationLocationCode = eDestinationLocation.Text
  TOLOCN.Findexact(TransfData.DestinationLocationCode)
  If ( TransfData.DestinationLocationCode = "TAS" or TransfData.DestinationLocationCode = "WGTN" or TransfData.DestinationLocationCode = "DBNZ") Then
    TransfData.TransitLocationCode = "TRANSIT"
  Else
    TransfData.TransitLocationCode = ""
  End If
  TransfData.Reference = eReference.Text
  TransfData.Z_ShipperCode = eCarrierCode.Text
  tblTransfers.First
  TransfData.Line.Empty
  Do until tblTransfers.Eof
    TransfData.Line.Append
    TransfData.Line.ProductCode = tblTransfers.ProductCode
    If IsDG = False Then CheckForDG(tblTransfers.ProductCode)
    If tblTransfers.Quantity = 0 Then
      If TOLocn.Z_Van = True Then TransfData.Line.QuantityReceipted = tblTransfers.Quantity 'Expected
      TransfData.Line.QuantityDispatched = tblTransfers.Quantity 'Expected
    Else
      If TOLocn.Z_Van = True Then TransfData.Line.QuantityReceipted = tblTransfers.Quantity 'Expected
      TransfData.Line.QuantityDispatched = tblTransfers.Quantity
    End If
    '      MSGBOX("trf = " & TransfData.Line.QuantityReceipted & " Ad= " & TransfData.Line.QuantityAdjusted  & " Dis= " & TransfData.Line.QuantityDispatched)
    TransfData.Line.Z_Sort_Bin = tblTransfers.BinKey
    TransfData.Line.Save
    tblTransfers.Next
  Loop
  TransfData.Save
ElseIf ReceiptMode then
  TransfData.Line.First
  Do Until TransfData.Line.EOF
    '-----
    tblTransfers.First
    Do Until tblTransfers.EOF
      If TransfData.Line.LineID = tblTransfers.LineID Then
        TransfData.Line.Edit
        '          If tblTransfers.Quantity < tblTransfers.QuantityExpected Then
        TransfData.Line.QuantityReceipted = tblTransfers.QuantityExpected
        '            TransfData.Line.QuantityAdjusted = 0
        '          Else
        '            TransfData.Line.QuantityAdjusted = 0
        '            TransfData.Line.QuantityReceipted = tblTransfers.Quantity
        '          End if
        TransfData.Line.QuantityAdjusted = 0 '
        TransfData.Line.Save
      End If
      If TransfData.EOF Then
        msgbox("Failed to Find matching Lines on Transfer")
        Exit Sub
      End If
      tblTransfers.Next
    Loop
    TransfData.Line.Next
    '-----
  Loop
  If eReceiptDate.value <> ## Then
    TransfData.ReceiptDate = eReceiptDate.value
    TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
  End If
  TransfData.Save
  
End If
'MSGBOX(TOLocn.Z_Van)
If Post = True Then
  If LoadMode Then
    TOLOCN.Findexact(TransfData.DestinationLocationCode)
    '      msgbox(TransfData.DestinationLocationCode)
    If TOLocn.Z_Van = True Then
      TransfData.Transfer
    Else
      TransfData.Dispatch
    End If
  End If
  If ReceiptMode then TransfData.Receipt
End If

'TransfData.openform
PrintTransf = TransfData.Print
'  PrintDG = TransfData.Print
PrintTransf.ReportFileName = "ICTransfer1_BarcodeEAN.pfd" '"ICTransfer_Modify.pfd"
If User.LoginUserName = "ACCREDO" then PrintTransf.Destination = "SCREEN"
'PrintTransf.Printer.PrinterName = "Hamilton Plain"
PrintTransf.Run

If TransfData.TransitLocationCode <> "" and IsDG and eMode.Text <> "RECEIPT MODE" Then
  PrintDG = TransfData.Print
  PrintDG.ReportFileName = "ICTransfer_DG.pfd"
  If User.LoginUserName = "ACCREDO" then PrintDG.Destination = "SCREEN"
  '    IF InputQuery("Print DG? - (Prompt to be removed after testing)") Then
  PrintDG.Run
  '    End IF
  PrintDG = Nothing
End If

Status
ForceClose = True
Self.close
End Sub


'Reset

Function CheckFailedLines
Difftable.empty
Returnprod = False
LineString = ""
tblTransfers.First
Do Until tblTransfers.EOF
  If tblTransfers.Quantity <> tblTransfers.QuantityExpected Then
    DiffQty = tblTransfers.Quantity - tblTransfers.QuantityExpected
    LineString = LineString & tblTransfers.ProductCode & " : " & tblTransfers.Description & " Expected: " & tblTransfers.QuantityExpected & " : Dispatched: " & tblTransfers.Quantity & " : Difference: " & DiffQty & chr(13)
    Returnprod = True
    tblReturn.Append
    tblReturn.ProductCode = tblTransfers.ProductCode
    tblReturn.Description = tblTransfers.Description
    tblReturn.Quantity = tblTransfers.Quantity - tblTransfers.QuantityExpected
    ' Old Modify tblReturn.Quantity = tblTransfers.QuantityExpected - tblTransfers.Quantity
    tblReturn.Expected = tblTransfers.QuantityExpected
    tblReturn.Dispatch = tblTransfers.Quantity
    tblReturn.Save
  End If
  tblTransfers.Next
Loop


Return LineString

End Function

Sub DeleteLine

If InputQuery("Are you sure you want to delete Product " & tblTransfers.ProductCode & " from the Transfer List?") Then
  If tblTransfers.LineID <> 0 AND DocID <> 0 Then
    If ICTFER.FindExact(DocID) Then
      LN = ICTFER.Line
      LN.First
      Do Until LN.EOF
        If LN.LineID = tblTransfers.LineID Then
          ICTFER.Edit
          LN.Delete
          ICTFER.Save
          Exit Do
        End If
        LN.Next
      Loop
    Else
      self.showerrorhint("Logic Error: Can't Find DocumentID: " & DocID)
      Abort("",True)
    End If
  Else
    ';;Just Delete off tblTransfers
  End If
Else
  Abort("",True)
End If

End Sub

Sub UpdateTransfer
LN = ICTFER.Line
tblTransfers.First
'  IF User.LoginUserName = "ACCREDO" Then BrowseDataset(tblTransfers)
Do Until tblTransfers.EOF
  '    IF User.LoginUserName = "ACCREDO" Then MSGBOX("Read " & tblTransfers.ProductCode & " Qty= " & tblTransfers.Quantity & " - " & LoadMode)
  If LoadMode Then
    '       IF User.LoginUserName = "ACCREDO" Then MSGBOX("At load" & tblTransfers.ProductCode & " Qty= " & tblTransfers.Quantity)
    If tblTransfers.Quantity = 0 Then
      ';;IF QUANTITIES ARE 0 WHICH MEANS THE PRODUCT WAS NOT SCANNED AND THE QUANTITIES WERE ACCEPTED
      
      '          IF InputQuery("Are you sure you want to delete Product " & tblTransfers.ProductCode & " from the Transfer List?") then
      
      If tblTransfers.LineID <> 0 AND DocID <> 0 Then
        
        If ICTFER.FindExact(DocID) Then
          ';;LOOP THROUGH TRANSFER'S LINES UNTIL IT FINDS A MATCH ON LINEID
          LN = ICTFER.Line
          LN.First
          FoundLine = False
          Do Until LN.EOF
            If LN.LineID = tblTransfers.LineID Then
              ICTFER.Edit
              LN.Delete
              ICTFER.Save
              tblTransfers.Delete
              Exit Do
            End If
            LN.Next
          Loop
        Else
          self.showerrorhint("Logic Error: Can't Find DocumentID: " & DocID)
          Abort("",True)
        End If 'ICTFER.Findexact
        
      Else
        msgbox("Logic Error Line No 777: No LineID= " & tblTransfers.LineID & " / DocID Match= " & DocID )
        Abort("",True)
        End IF'LineID <> 0 DocID <> 0
        
        '          Else
        ''            MSGBOX("Despatch will fail with Zero Qty Line")
        '            tblTransfers.Next
        '          End IF 'InputQuery to Delete
      Else 'tblTransfers.Quantity <> 0 but is d
        LN = ICTFER.Line
        '          tblTransfers.First
        '          IF User.LoginUserName = "ACCREDO" Then MSGBOX("Read2")
        ICTFER.Edit
        If ICTFER.Z_ShipperCode = "" and eCarrierCode.Text <> "" Then
          ICTFER.Z_ShipperCode = eCarrierCode.Text
        End If
        '          Do Until tblTransfers.EOF
        If tblTransfers.Quantity <> LN.QuantityDispatched Then
          LN.First
          Do Until LN.EOF
            If LN.LineID = tblTransfers.LineID Then
              LN.Edit
              LN.QuantityDispatched = tblTransfers.Quantity
              LN.Z_Sort_Bin = tblTransfers.BinKey
              LN.Save
              Exit Do
            End If
            LN.Next
          Loop
        End If
        tblTransfers.Next
        '          Loop
        ICTFER.Save
      End If 'tblTransfers.Quantity = 0
      
    ElseIf tblTransfers.Quantity <> tblTransfers.QuantityExpected then
      ';;IF NOT LOADMODE
      '          IF User.LoginUserName = "ACCREDO" Then MSGBOX("Not Load")
      If ICTFER.FindExact(DocID) Then
        LN = ICTFER.Line
        LN.First
        Do Until LN.EOF
          If LN.LineID = tblTransfers.LineID Then
            ICTFER.Edit
            If ICTFER.Z_ShipperCode = "" and eCarrierCode.Text <> "" Then
              ICTFER.Z_ShipperCode = eCarrierCode.Text
            End If
            LN.Edit
            If LoadMode Then
              LN.QuantityDispatched
            ElseIf ReceiptMode then
              '                LN.QuantityAdjusted = tblTransfers.Quantity - tblTransfers.QuantityExpected
              LN.QuantityReceipted = tblTransfers.QuantityExpected
            End If
            LN.Save
            ICTFER.Save
            Exit Do
          End If
          LN.Next
        Loop
      End If
      tblTransfers.Next
    Else
      tblTransfers.Next
    End If
  Loop
  '  IF User.LoginUserName = "ACCREDO" Then MSGBOX("B4 Sub")
End Sub

Sub CompleteTransfer
  
  If OpenExisting = True Then
    Log = CheckFailedLines
    If User.LoginUserName = "ACCREDO" Then MSGBOX("Complete Transfer")
    If Log <> "" Then
      If InputQuery("The Following Products Have Different Quantities to the Original Transfer: " & chr(13) & _
        Log & chr(13) & _
        IIF(LoadMode,"Would You Like to Proceed With The Current Quantities?","Would You Like to Proceed With The Current Quantities and Mark any Variances as Adjustments?")) then
      UpdateTransfer
      If ReturnProd = True Then
        If ReceiptMode Then
          If User.LoginUserName = "ACCREDO" Then MSGBOX("Receipt Mode")
          Dim TransfData as Object
          TransfData = CreateObject("Accredo.ICTransferData")
          TransfData.InsertTransfer
          TransfData.DocumentDate = Date
          TransfData.ReceiptDate = Date
          TransfData.PeriodID = PeriodforDate(TransfData.DocumentDate)
          TransfData.ReceiptPeriodID = PeriodforDate(TransfData.ReceiptDate)
          TransfData.SourceLocationCode = eDestinationLocation.Text
          TransfData.DestinationLocationCode = eSourceLocation.Text
          If ( TransfData.DestinationLocationCode = "TAS" or TransfData.DestinationLocationCode = "WGTN" or TransfData.DestinationLocationCode = "DBNZ") Then
            TransfData.TransitLocationCode = "TRANSIT"
          Else
            TransfData.TransitLocationCode = ""
          End If
          TransfData.Reference = "Undelivered trf"
          TransfData.Comment = "Undelivered Trf"
          TransfData.Z_ShipperCode = ""
          tblReturn.First
          
          TransfData.Line.Empty
          Do until tblReturn.Eof
            TransfData.Line.Append
            TransfData.Line.ProductCode = tblReturn.ProductCode
            TransfData.Line.Dispatch = tblReturn.Quantity * -1
            TransfData.Line.Receipt = tblReturn.Quantity * -1
            TransfData.Line.Save
            tblReturn.Next
          Loop
          TransfData.Save
          TransfData.Transfer
          Dim Printername as String
          If left(eSourceLocation.text,1) = "C" Then
            PRINTERNAME = "CHCH_HP M570"
          ElseIf left(eSourceLocation.text,1) = "W" Then
            PRINTERNAME = "Toshiba Wellington" '"HP Wellington B&W"
          Else
            '                  PRINTERNAME = "HP LaserJet Pro MFP M127-M128 PCLmS"
            Printername = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
            
          End If
          PrintTransf = TransfData.Print
          PrintTransf.ReportFileName = "ICTransfer1_BarcodeEAN.pfd"
          If User.LoginUserName = "ACCREDO" Then
            PrintTransf.Destination = "SCREEN"
          Else
            PrintTransf.Printer.PrinterName = PRINTERNAME
          End If
          PrintTransf.Run
          If left(eDestinationLocation.text,1) = "C" Then
            PRINTERNAME = "CHCH_HP M570"
          ElseIf left(eDestinationLocation.text,1) = "W" Then
            PRINTERNAME = "Toshiba Wellington" '"HP Wellington B&W"
          Else
            '                  PRINTERNAME = "HP LaserJet Pro MFP M127-M128 PCLmS"
            Printername = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
          End If
          PrintTransf = TransfData.Print
          PrintTransf.ReportFileName = "ICTransfer1_BarcodeEAN.pfd"
          If User.LoginUserName = "ACCREDO" Then
            PrintTransf.Destination = "SCREEN"
          Else
            PrintTransf.Printer.PrinterName = PRINTERNAME
          End If
          PrintTransf.Run
          
        ElseIf LoadMode then
          Dim Mailer as object
          Mailer = createobject("Accredo.SMTPMailer")
          '                IF eDestinationLocation.value = "CHC" or eDestinationLocation.value = "WGTN" or eDestinationLocation.value = "HV1" Then
          '                  IF eDestinationLocation.value = "CHC" Then
          '                    Mailer.To = "mark.floris@linkup.co.nz"
          '                  ElseIF eDestinationLocation.value = "WGTN" Then
          '                    Mailer.To = "brian.church@linkup.co.nz"
          '                 '   Mailer.bcc = "colin@zealsystems.co.nz
          '                  ElseIF eDestinationLocation.value = "HV1" Then
          '                    Mailer.To = "daryl.landers@linkup.co.nz"
          '                  '  Mailer.bcc = "colin@zealsystems.co.nz"
          '                  End if
          '
          '                  Mailer.BCC = "freight@linkup.co.nz" ';colin@zealsystems.co.nz"
          '                  Mailer.From = "freight@linkup.co.nz"
          '                  Mailer.Subject = "Product Transfer Request - Differences ID = " & DocId
          '                  Mailer.Contents.Text = LOG
          '                  EDI = createreport(tblReturn, "Transfer Differenct Report" )
          '                  EDI.Destination = "Disk file"
          '                  EDI.FileName = Directory.SystemDirectory & "TransferReports\"& eDestinationLocation.value & "_" & DocId & ".pdf"
          '
          '                  EDI.Run
          '                  AttFile = Directory.SystemDirectory & "TransferReports\"& eDestinationLocation.value & "_" & DocId & ".pdf"
          ''                  Mailer.Attachments = Directory.SystemDirectory & "TransferReports\"& eDestinationLocation.value & "_" & DocId & ".pdf"
          '                  Mailer.Attachments = Attfile
          ''                  MSGBOX("Email Subject: " & "Product Transfer Request - Differences ID = " & DocId)
          ''                  MSGBOX("Email: " & LOG)
          ''                  MSGBOX("Att= " & Mailer.Attachments)
          '                  Try
          '                    IF User.LoginUserName <> "ACCREDO" then Mailer.Send
          '                    Deletefile(Attfile)
          '                  Catch e
          '                    ErrorMsg = e.Message & chr(13) & e.SourcePos & Chr(13) & e.ExceptionClass & Chr(13) & "Mailer To = " & Mailer.To & Chr(13) & LOG
          '                    Msgbox(ErrorMsg)
          '                  End Try
          '                End If
          TOLOCN.Findexact(eDestinationLocation.text)
          '               If TOLocn.Z_Van = True Then
          Dim ICTFER as Object
          ICTFER = opentable("ICTFER")
          ICTFER.indexname = "TypeDestinationPeriodDocument"
          Dim BackOrderData as Object
          BackOrderData = CreateObject("Accredo.ICTransferData")
          BackorderData.Indexname = "Document"
          TfrPer = Periodfordate(Date)
          ICTFER.SetRange("N",eDestinationLocation.text,TFRPer)
          TRFFound = False
          ICTFER.First
          '                  MSGBOX(TRFFound & " - " & ICTFER.DocumentID & " Per= " & Tfrper)
'          Do Until ICTFER.EOF
'            If left(ICTFER.Comment,6) = "+Auto-" and ICTFER.DocumentID <> DocId Then
'              TRFFound = True
'
'              Exit Do
'            End If
'            ICTFER.Next
'          Loop

          Do Until ICTFER.EOF
            If left(ICTFER.Comment,6) = "+Auto-" and ICTFER.DocumentID <> DocId Then
              If BackOrderData.Findexact(ICTFER.DocumentID) Then
                If BackOrderData.PostStatus <> "D" and BackOrderData.PostStatus <> "P" Then
                  TRFFound = True
                  Exit Do
                End If
              End If
            End If
            ICTFER.Next
          Loop
          '                  MSGBOX(TRFFound & " - " & ICTFER.DocumentID)
          Prttrf = False
          If TRFFound = True Then
            BackOrderData.Findexact(ICTFER.DocumentID)
            BackOrderData.Edit
          Else
            BackOrderData.InsertTransfer
            BackOrderData.DocumentDate = eTransferDate.value
            BackOrderData.ReceiptDate = eTransferDate.value
            BackOrderData.PeriodID = PeriodforDate(BackOrderData.DocumentDate)
            BackOrderData.ReceiptPeriodID = PeriodforDate(BackOrderData.ReceiptDate)
            BackOrderData.SourceLocationCode = eSourceLocation.Text
            BackOrderData.DestinationLocationCode = eDestinationLocation.Text
            If (BackOrderData.DestinationLocationCode = "TAS" or BackOrderData.DestinationLocationCode = "WGTN" or BackOrderData.DestinationLocationCode = "DBNZ") Then
              BackOrderData.TransitLocationCode = "TRANSIT"
            Else
              BackOrderData.TransitLocationCode = ""
            End If
            BackOrderData.Comment = "+Auto-BackOrder"
            BackOrderData.Reference = eReference.Text
          End If
          tblReturn.First
          Do until tblReturn.Eof
            If tblReturn.Quantity < 0 Then
              prttrf = True
              ProdFound = False
              BackOrderData.Line.First
              Do Until BackOrderData.Line.EOF
                
                If BackOrderData.Line.ProductCode = tblReturn.ProductCode Then
                  BackOrderData.Line.Edit
                  BackOrderData.Line.Dispatch = BackOrderData.Line.Dispatch + (tblReturn.Quantity * -1)
                  ProdFound = True
                  Exit Do
                End If
                
                BackOrderData.Line.Next
              Loop
              If ProdFound = False Then
                If tblReturn.ProductCode <> "" Then
                  BackOrderData.Line.Append
                  BackOrderData.Line.ProductCode = tblReturn.ProductCode
                  BackOrderData.Line.Dispatch = tblReturn.Quantity * -1
                End If
                '                      MSGBOX("Return = " & BackOrderData.Line.Dispatch)
                ' Old Modify removed * -1
              End If
              BackOrderData.Line.Save
            End If
            tblReturn.Next
          Loop
          BackOrderData.Save
          '                  IF eDestinationLocation.value = "HV1" and prttrf = True Then
          '                    PrintBO = BackOrderData.Print
          '                    PrintBO.ReportFileName = "ICTransfer1_BarcodeEAN.pfd"
          '                    Dim Printername as String
          ''                    PRINTERNAME = "HP LaserJet Pro MFP M127-M128 PCLmS"
          '                    Printername = "TOSHIBA e-S2802A"
          '                    PrintBO.Printer.PrinterName = PRINTERNAME
          '                    IF User.LoginUserName <> "ACCREDO" then PrintBo.run
          '                  End If
          btnComplete.ShowStatusHint("BackOrder Transfer Created")
          '    End if
        Else
        End If
      End If
    Else
      IIF(LoadMode,btnComplete.ShowErrorHint("Dispatch Aborted"),btnComplete.ShowErrorHint("Complete Aborted"))
      Exit Sub
    End If
  Else
    btnComplete.ShowStatusHint("All Lines Complete")
  End If
End If


'TransferExitForm = Createcustomform("Barcoding\TransferExitForm.pfd")
'TransferExitForm.ShowModal
'Dim ExitStatus as String
'ExitStatus = TransferExitForm.pExitStatus
'If ExitStatus = "TransferAndPost" then
SaveTransfer(True)
Dim Printername as String
If left(eDestinationLocation.text,1) = "C" Then
  PRINTERNAME = "CHCH_HP M570"
ElseIf left(eDestinationLocation.text,1) = "W" Then
  PRINTERNAME = "Toshiba Wellington" '"HP Wellington B&W"
Else
  '      PRINTERNAME = "HP LaserJet Pro MFP M127-M128 PCLmS"
  Printername = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
End If
'   MSGBOX(" - Doc Id B - " & DocID)
Trftable = ExecuteSql("SELECT ICTFER.DocumentID " & _
  " ,ICTFER.DocumentDate " & _
  " ,ICLINE.ProductCode " & _
  " ,icline.QuantityReceipted " & _
  " ,ICPROD.Description " & _
  " ,ICPEND.Class " & _
  " ,ICPEND.LocationCode " & _
  " ,ICPEND.SourceDocumentID " & _
  " ,ICPEND.Quantity " & _
  " ,OEHEAD.CustomerCode " & _
  " ,OEHEAD.OrderNo " & _
  " ,OEHEAD.SalesPersonCode " & _
  "FROM ICTFER " & _
  " INNER JOIN ICLINE ON ICTFER.DocumentID=ICLINE.DocumentID " & _
  " INNER JOIN ICPEND ON ICPEND.ProductCode=ICLINE.ProductCode and ICPEND.LocationCode = ICTFER.DestinationLocationCode " & _
  " INNER JOIN OEHEAD ON OEHEAD.DocumentID=ICPEND.SourceDocumentID " & _
  " inner Join ICPROD on ICProd.productCode = ICLINE.ProductCode " & _
  "WHERE (ICTFER.DocumentID = :DocumentID " & _
  " AND ICPEND.Class = 'B' " & _
  " and icline.QuantityReceipted > 0) " DocID )
If Trftable.recordMax > 0 Then
  Dim Form15 as Object
  Form15 = CreateObject("Accredo.UTCustomReport")
  Form15.ReportFileName = "Trf_OutstandingCustomerOrders.pfd"
  '      IF User.LoginUserName = "ACCREDO" Then
  Form15.Destination = "Screen"
  Form15.Run(DocID)
Else
  eBarcode.SetFocus
End If

ToLocn.FindExact(eDestinationLocation.Text)
If ToLocn.Z_Van = True Then
  If InputQuery("Do you wish to print VAN DG reports?") Then
    Locn = eDestinationLocation.text 'eSourceLocation.text 'User.DefaultLocationCode
    If Left(Locn,1) = "D" Then
      MyPrinter = "DBNZ_Bunker" '"TOSHIBA e-S2802A"
    ElseIf Left(Locn,1) = "W" then
      MyPrinter = "Toshiba Wellington" ' "HP Wellington B&W"
    Else
      MyPrinter = "SCREEN"
    End If
    Dim Vanreport1 as string
    Dim Vanreport2 as string
    Vanreport1 = Directory.SystemDirectory & "\Reports\Custom\DangerousGoodsStockReportDP.pfd"
    Vanreport2 = Directory.SystemDirectory & "\Reports\Custom\DangerousGoodsCertificateAndDeclaration.pfd"
    Dim Report1 as Object
    Report1 = CreateObject("Accredo.UTCustomReport")
    Report1.ReportFileName = Vanreport1
    Report1.Destination = "Printer"
    Report1.Printer.PrinterName = MyPrinter
    Report1.Run
    Report1 = Nothing
    Dim Report2 as Object
    Report2 = CreateObject("Accredo.UTCustomReport")
    Report2.ReportFileName = Vanreport2
    Report2.Destination = "Printer"
    Report2.DPrinter.PrinterName = MyPrinter
    Report2.Run
    Report2 = Nothing
  End If
End If
'  Reset
'ElseIf ExitStatus = "Transfer" then
' SaveTransfer(False)
' Reset
'ElseIf ExitStatus = "Close" then
'Else
'Error("Exit Status Unkown")
'End IF
'  eBarcode.SetFocus
End Sub


Sub OnEnter
eBarcode.Text = ""
tblTransfers.IndexName = "BinKey"
End Sub


Sub OnLeave
If SourceLocation and DestinationLocation and eBarcode.text = "000000000000" Then
  CompleteTransfer
  '    GenerateInvoice
ElseIf eBarcode.text <> "" then
  If Not StaffScan Then
    If Upper(LEFT(eBarcode.value,5)) = "STAFF" Then
      eReference.Text = Upper(Mid(eBarcode.value,6,20))
      StaffScan = True
      
    Else
      eBarcode.Showerrorhint("Scan Staff")
    End If
  ElseIf eCarrierCode.Text = "" and CarierReqd Then
    ICBAR.indexname = "Barcode"
    If ICBAR.Findexact(eBarcode.text) Then
      eProductCode.Text = ICBAR.ProductCode
      If ICPROD.FIndexact(ICBAR.ProductCode) Then
        If Upper(Left(ICProd.Category2,7))= "FREIGHT" Then
          eCarrierCode.Text = ICProd.ProductCode
          CarrierScan = True
          eCarrierCode.Enabled = CarrierScan
          
        Else
          eBarcode.Showerrorhint("Code selected not a Freight Code")
        End If
      End If
    Else
      eBarcode.Showerrorhint("Carrier Not Found")
    End If
    '        MSGBOX("Select Carrier before scanning Barcodes")
  Else
    ProductScanCheck
  End If
  
End If
Status
If eBarcode.Text <> "" then eBarcode.SetFocus
End Sub

Sub Product_Click
If eStatus.text = "Scan Product" Then
  eBarcode.text = tbltransfers.ProductCode
  ProductScanCheck
End If
End Sub


Sub ChangeQuantity

tblTransfers.Fields.Item("ProductCode").Readonly = False
tblTransfers.Fields.Item("Quantity").Readonly = False


If eproductCode.text <> "" Then
  tblTransfers.indexname = "Product"
  If tblTransfers.Findexact(eproductCode.text) Then
    tblTransfers.IndexName = "BinKey"
    CalcForm = Createcustomform("Barcoding\Qty_Entry.pfd")
    CalcForm.pProductCode = eproductCode.text
    CalcForm.pOrder = False
    '      CalcForm.pOrderedQTY = tblTransfers.QuantityOrdered
    '      CalcForm.pLPickedQty = tblTransfers.QuantityOutstanding
    CalcForm.ShowModal
    If CalcForm.eExitStatus.Checked = True Then
      btnButton2.showstatushint("Cancelled")
      If Not InsertMode Then
        tblTransfers.Fields.Item("ProductCode").Readonly = True
        tblTransfers.Fields.Item("Quantity").Readonly = True
      End If
      Exit Sub
    End If
    tblTransfers.Edit
    tblTransfers.Quantity = CalcForm.pPickedQty
    Try
      tblTransfers.Adjustment = tblTransfers.Quantity - tblTransfers.QuantityExpected
      tblTransfers.QtyOutstanding = tblTransfers.QuantityExpected - tblTransfers.Quantity
    Catch
    End Try
    '      tblTransfers.QuantityOutstanding = tblTransfers.QuantityOrdered - tblTransfers.QuantityScanned
    tblTransfers.Save
    tblTransfers.IndexName = "BinKey"
    ProductDetails
  Else
    eBarcode.Showerrorhint("Item Not Found On Transfer: " & eProductCode.Text)
  End If
Else
  eproductCode.Showerrorhint("Scan Product First")
End If

If Not InsertMode Then
  tblTransfers.Fields.Item("ProductCode").Readonly = True
  tblTransfers.Fields.Item("Quantity").Readonly = True
End If
eBarcode.SetFocus
End Sub

Sub Ref_Leave
eBarcode.SetFocus
';;DISABLED TEMPORARILY AS THE SAVE BUTTON IS HAVING TO BE CLICKED TWICE IF COMING FROM THE REFERENCE BOX
End Sub



Sub AddNewItem
If not SourceLocation Then
  eBarcode.Showerrorhint("Scan Source Location")
ElseIf not DestinationLocation Then
  eBarcode.Showerrorhint("Scan Destination Location")
ElseIf not StaffScan Then
  eBarcode.Showerrorhint("Scan Staff Reference")
Else
  AddNewItemForm = Createcustomform("Barcoding\OrderPicking_AddProductToOrder.pfd")
  AddNewItemForm.ShowModal
  Dim NewProduct as String
  NewProduct = AddNewItemForm.pNewProduct
  NewBarcode = AddNewItemForm.pNewBarcode
  If NewProduct <> "" Then
    tblTransfers.Indexname = "Product"
    If tblTransfers.Findexact(NewProduct) Then
      MSGBOX("Product already exists on Transfer")
    Else
      tblTransfers.AllowInsertDelete = True
      tblTransfers.Fields.Item("ProductCode").Readonly = False
      tblTransfers.Fields.Item("Quantity").Readonly = False
      tblTransfers.Append
      'tblTransfers.NewRow = True
      tblTransfers.ProductCode = NewProduct
      eproductCode.text = NewProduct
      If ICPROD.Findexact(NewProduct) Then
        tblTransfers.Description = ICPROD.DEscription
      End If
      
      tblTransfers.Quantity = 1
      
      '    tblTransfers.QuantityPicked = 1
      '    tblTransfers.QuantityOrdered = 1
      tblTransfers.Save
      tblTransfers.Fields.Item("ProductCode").Readonly = true
      tblTransfers.Fields.Item("Quantity").Readonly = True
      'tblTransfers.AllowInsertDelete = False
    End If
  End If
  Call ProductDetails
  '  tblTransfers.indexname = "Order"
  eBarcode.SetFocus
End If
End Sub



Sub navGrid_Click(Sender as Object,Button as Number, Handled as Boolean)

If Button = ebDelete Then
  DeleteLine
End If

End Sub]]>
