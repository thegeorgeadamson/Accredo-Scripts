Accredo,CustomReport,72,CustomReportClass
Report="Lot Expiry Report",P,"Calibri,9,0",1,"",3
Margins=10.00,10.00,10.00,10.00
BeforeReport=TotalInStock = 0
=TotalAllocated = 0
=TotalAvailable = 0
=Dim scForm as Object
=scForm = CreateObject("Accredo.ScriptedForm")
=scForm.Caption = "Expiry Report Selections"
=scForm.InputInteger("MonthsAhead", "Months ahead")
=scForm.SetValue("MonthsAhead", 3)
=Do
=  If Not scForm.Execute Then
=    Abort("", True)
=  Else
=    MonthsAhead = scForm.GetValue("MonthsAhead")
=    If MonthsAhead > 0 Then
=      Exit Do
=    End If
=  End If
=Loop
=Params.MonthsAhead = MonthsAhead
