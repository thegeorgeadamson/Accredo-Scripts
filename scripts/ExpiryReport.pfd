Iterator=Query,"","",bandStandard
SQL=SELECT ICTRKQTY.ProductCode AS Product
=      ,ICPROD.Description
=      ,ICPROD.StockGroupCode AS StockGroup
=      ,ICTRKQTY.LocationCode AS Location
=      ,ICTRKQTY.LotNo
=      ,CAST(ICTRKQTY.ExpiryDate AS DATE) AS ExpiryDate
=      ,ICTRKQTY.QuantityInStock AS InStock
=      ,ICTRKQTY.QuantityAllocated AS Allocated
=      ,ICTRKQTY.QuantityAvailable AS Available
=FROM ICTRKQTY
=INNER JOIN ICPROD ON ICTRKQTY.ProductCode = ICPROD.ProductCode
=WHERE ICTRKQTY.ExpiryDate >= Current_date
=AND ICTRKQTY.ExpiryDate <= AddMonths(Current_date, :MonthsAhead)
=AND ICTRKQTY.QuantityInStock > 0
=ORDER BY ICTRKQTY.ExpiryDate, ICTRKQTY.ProductCode
Param="MonthsAhead","3",N
ManualChange=Y
Wizard=3
Report="Lot Expiry Report"
Selections=""
RetainBeforeReport="N"
RetainAfterQuery="N"
PageOrientation="Automatic"
Column="Product","Product",20,"Yes","No",0,"No"
Column="Description","Description",25,"Yes","No",0,"No"
Column="StockGroup","Stock Group",10,"Yes","No",0,"No"
