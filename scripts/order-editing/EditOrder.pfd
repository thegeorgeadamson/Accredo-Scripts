      </TnStringField>
      <TnDateField DisplayLabel="Date" DisplayWidth="10" FieldName="DocumentDate">
      </TnDateField>
    </TUserMemoryTable>
    <TUserMemoryTable Active="True" AfterDelete="" AfterScroll="" BeforeDelete="" IndexName="" Name="tblPreview" OnCanDelete="" OnCanInsert="" OnCanModify="" OnNewRecord="" Left="10" Top="100">
      <TnUpperField DisplayLabel="Code" DisplayWidth="20" FieldName="ProductCode" Visible="False">
      </TnUpperField>
      <TnStringField DisplayLabel="Description" DisplayWidth="55" FieldName="Description" Size="200">
