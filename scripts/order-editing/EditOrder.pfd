<Design Version="1" DPI="96">
  <Form Caption="Edit Order Lines" Color="clBtnFace" Constraints.MaxHeight="52428" Constraints.MaxWidth="52428" Constraints.MinHeight="100" Constraints.MinWidth="200" Font.Charset="DEFAULT_CHARSET" Font.Color="clWindowText" Font.Height="-14" Font.Name="Arial" Font.Style="" Height="750" Interactive="True" OnClose="" OnShow="" SaveSizeName="" Visible="False" Width="1200" WindowState="wsMaximized">
