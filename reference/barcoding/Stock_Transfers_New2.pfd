      </TUserButton>
      <TUserButton Anchors="akTop;akRight" Caption="Add Item" Height="48" ImageIndex="2034" Left="7" Name="btnAdditem" OnClick="AddNewItem" ShortCut="0" TabOrder="1" TabStop="True" Top="58" Width="98">
      </TUserButton>
      <TUserButton Anchors="akTop;akRight" Caption="Delete" Height="48" Hint="Delete Line" ImageIndex="2035" Left="107" Name="btnDeleteLine" OnClick="btnDeleteLine_Click" ShortCut="0" TabOrder="2" TabStop="False" Top="58" Width="68">
      </TUserButton>
    </TUserGroupBox>
    <TUserGroupBox Caption="Reference" Height="54" Left="573" Name="grpGroupBox5" TabOrder="7" Top="7" Width="164">
