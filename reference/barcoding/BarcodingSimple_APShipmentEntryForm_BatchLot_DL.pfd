<?xml version="1.0" encoding="UTF-8"?>
<Design Version="3" DPI="96">
  <Form BorderStyle="bsDialog" Caption="Barcode" Color="clBtnFace" Constraints.MinHeight="100" Constraints.MinWidth="200" Font.Charset="DEFAULT_CHARSET" Font.Color="clWindowText" Font.Height="-12" Font.Name="Segoe UI" Font.Style="" Height="220" Interactive="True" OnCreate="OnCreate" OnDestroy="OnDestroy" OnShow="OnShow" SaveSizeName="frmBarcodingSimple_OEForm" Visible="False" Width="479" WindowState="wsNormal">
    <TUserPanel Align="alClient" AlternateColour="False" BevelOuter="bvNone" Color="15259083" Height="192" Left="0" Name="panMain" TabOrder="0" Top="0" Width="473">
