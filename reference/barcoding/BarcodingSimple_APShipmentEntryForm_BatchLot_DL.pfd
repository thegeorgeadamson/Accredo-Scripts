      <TUserNumberEdit Align="alNone" Alignment="taRightJustify" Anchors="akLeft;akTop" CalculatorFontSize="8" CurrencyCode="" Decimals="0" Domain="" Height="22" LabelCaption="Quantity" Left="13" Name="eQty" OnChange="" OnEnter="" OnExit="" TabOrder="9" TabStop="True" Text="1" Top="106" Width="417">
      </TUserNumberEdit>
