      </TUserPanel>
      <TUserNumberEdit Align="alNone" Alignment="taRightJustify" Anchors="akLeft;akTop" CalculatorFontSize="8" CurrencyCode="" Decimals="0" Domain="" Height="22" LabelCaption="Document Id" Left="13" Name="eDocumentId" OnChange="" OnEnter="" OnExit="" ReadOnly="True" TabOrder="1" TabStop="True" Text="" Top="19" Width="250">
      </TUserNumberEdit>
      <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Height="22" LabelCaption="Status" Left="13" Name="eStatus" OnChange="" OnEnter="" OnExit="" ReadOnly="True" TabOrder="2" TabStop="True" Text="" Top="46" Width="426">
      </TUserEdit>
      <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Height="22" LabelCaption="Barcode" Left="13" Name="eBarcode" OnChange="" OnEnter="eBarcode_OnEnter" OnExit="eBarcode_OnExit" TabOrder="3" TabStop="True" Text="" Top="136" Width="403">
      </TUserEdit>
      <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Height="22" LabelCaption="Lot No" Left="13" Name="eBatchID" OnChange="" OnEnter="eBarcode_OnEnter" OnExit="eBarcode_OnExit" ReadOnly="True" TabOrder="4" TabStop="True" Text="" Top="78" Width="403">
      </TUserEdit>
      <TUserEdit Align="alNone" Alignment="taLeftJustify" Anchors="akLeft;akTop" Height="22" LabelWidth="0" Left="419" Name="eEdit1" OnChange="" OnEnter="" OnExit="" TabOrder="5" TabStop="True" Text="" Top="136" Width="20">
      </TUserEdit>
      <TUserPanel Align="alRight" AlternateColour="False" BevelOuter="bvNone" Color="8404992" Height="182" Left="468" Name="panPanel4" TabOrder="6" Top="5" Width="5">
      </TUserPanel>
