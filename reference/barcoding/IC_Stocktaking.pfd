Private Sub PopulateGrids(byref table as Object, byref memTable as Object, byref cloneTable as Object)
  'BrowseDataSet(memTable)
  'table.ReadOnly = False
'  ReadAllow
'  Msgbox(table.Name)
  cloneTable.empty
  memTable.First
  Do Until memTable.EOF
    CloneTable.Append
    IF ICPROD.Findexact(memTable.ProductCode) then
      cloneTable.Description = ICPROD.Description
    End IF
    CopyFieldsByName(memTable, cloneTable)

    CloneTable.Save
   memTable.Next
  Loop
  table.refresh
  table.First
End Sub


Sub Load_Form
Dim Form as Object
Form = CreateObject("Accredo.ScriptedForm")
Form.Caption = "New Stocktake Form"
Form.InputCode("Location","ICLOCN", "Location")
Form.inputbox("Bin","Bin")
Do
  If Form.Execute Then
    Location = Form.GetValue("Location")
    Bin = Form.GetValue("Bin")
    If Location <> "" Then
      Exit Do
    Else
      MsgBox("Please select a Location code")
    End If
  Else
    Abort("Cancelled by User")
  End If
Loop

Self.Caption = Self.Caption & " - " & Location
'                     "       ,(ICQTY.QuantityInstock + ICQTY.StocktakeVariance) as Quantity " & chr(13) & _
'IF Bin <> "" then
  DIM ICQTY as Object
  ICQTY = Executesql(" Select ICQTY.ProductCode " & chr(13) & _
                     "       ,ICQTY.Binlocation " & chr(13) & _
                     "       ,ICQTY.QuantityInstock " & chr(13) & _
                     "       ,(ICQTY.StocktakeVariance - ICQTY.QuantityInstock) as Variance " & chr(13) & _
                     "       ,ICQTY.QuantityAllocated " & chr(13) & _
                     "       ,ICQTY.Z_BinLocation2 as BinLocation2 " & chr(13) & _
                     " FROM   ICPROD " & chr(13) & _
                     "        INNER JOIN ICQTY  ON ICPROD.ProductCode=ICQTY.ProductCode " & chr(13) & _
                     " WHERE (ICPROD.Inactive = False) " & chr(13) & _
      IIF(Bin=""," ","   AND (ICQTY.Binlocation = '" & Bin & "' or ICQTY.Z_BinLocation2 = '" & Bin & "') ") &_
                     "   And ICQTY.LocationCode = :Loc ", Location)
  PopulateGrids(tblStocktake, ICQTY, tblStocktake_Clone)
'End IF
'if User.LoginUserName = "ACCREDO" Then Browsedataset(tblStocktake)
tblStocktake.Fields.Item("ProductCode").ReadOnly = True

  Executesql("SELECT   ICPROD.ProductCode " & _
                    "        ,Sum(ICPEND.Quantity) As Qty" & _
                    "        ,ICPEND.LocationCode " & _
                    "        ,ICPEND.SourceModule " & _
                    "FROM   ICPROD " & _
                    "       INNER JOIN ICPEND  ON ICPROD.ProductCode=ICPEND.ProductCode " & _
                    "WHERE  ICPEND.SourceModule IN('IN','OE') " & _
                    "   And (ICPEND.LocationCode = :Loc) " &_
                    "GROUP BY ICPROD.ProductCode " & _
                    "        ,ICPEND.LocationCode " & _
                    "        ,ICPEND.SourceModule ", Location,tblvariance)

'if User.LoginUserName = "ACCREDO" Then Browsedataset(tblvariance)

tblStocktake.indexname = "Product"
  tblvariance.First
  Do Until tblvariance.EOF

    IF tblStocktake.Findexact(tblvariance.Productcode) then
        tblStocktake.Edit
      If tblvariance.SourceModule = "OE" Then tblStocktake.AlloOE = tblvariance.QTY * -1
      If tblvariance.SourceModule = "IN" Then tblStocktake.AlloIN = tblvariance.QTY * -1
      tblStocktake.Save
    End IF


   tblvariance.Next
  Loop



'MSGbox("DOne")

'browsedataset(tblvariance)


End Sub



Sub Reset
  StaffScan = False
  eDocID.Value = 0
  tblStocktake.Empty
  btnComplete.Enabled = True
'  eCreditorCode.Text = ""
'  eCreditorName.Text = ""
'  eTransferDate.Value = Date
End Sub
Reset

tblStocktake.AllowInsertDelete = False
'eTransferDate.Value = Systemdate

Sub ProductDetails
  IF ICPROD.FIndexact(tblStocktake.ProductCode) then
    eProductCode.Text = ICPROD.ProductCode
    eProductName.Text = ICPROD.Description
    'eInStock.Value = ICPROD.QuantityInStock
    IF ICQTY.Findexact(tblStocktake.ProductCode, Location) THen
      eInStock.Value = ICQTY.Quantityinstock
    Else
      eInStock.Value = 0
    End IF
    if ApplicationSetting( "IC\ValuationBasis") = "L" Then
      eCostPrice.Text = formatNumber(ICPROD.LatestCost,"Amount")
    Elseif ApplicationSetting( "IC\ValuationBasis") = "A" Then
      eCostPrice.Value = ICPROD.AverageCost
    Elseif ApplicationSetting( "IC\ValuationBasis") = "S" Then
      eCostPrice.Value = ICPROD.StandardCost
    End IF
  End IF
  ePicked.Value = tblStocktake.Quantity
End Sub


