Sub CompleteStockTake


If inputQuery("Import into Stocktake") then
 Dim Directory as object
 Directory = Createobject("Accredo.Directory")
 FiletoUse = Directory.SystemDirectory & "Stocktake - " & Formatdatetime(Date,"DDMMYY")  & ".TXT"
  tblExport.Refresh
  tblExport.SaveToFile(FiletoUse)

  Dim Form1 as Object
  Form1 = CreateObject("Accredo.ICStocktakeImportForm")
  Form1.FileName = FiletoUse
  Form1.Location = Location
  'Form1.CompareBasis = "Closing Stock (Current Period)"
  Form1.CompareBasis = "Stock on Hand (Incl. Future)"

  Form1.Run

    Dim Form1 as Object
    Form1 = CreateObject("Accredo.ICStockTakeVarianceReport")
    Form1.Layout = "Stocktake Variance Report"
    Form1.Location = Location
    Form1.Destination = "Printer"
'    IF Bin <> "" then Form1.ReportFilterSort.Filter = "(BinLocation=""" & Bin  & """)"
'    Form1.Destination = "Printer"
'    IF Company.CompanyCode = "LINKUP" OR Company.CompanyCode = "PSGLTD" then
'      Form1.Printer.PrinterName = "\\LUPS-DC1\HP LJP1606DN - Inward Goods"
'    End IF
    Form1.Run
    Do
    Dim WhatNextForm as Object
    WhatNextForm = CreateCustomForm("Barcoding\IC_StockTakeWhatNext.pfd")
    WhatNextForm.ShowModal
    WNFormExitStatus = WhatNextForm.pExitStatus
    WNFormExitDate = WhatNextForm.PDate
    If WNFormExitStatus = Upper("AdjustVariance") Then
      IF Not inputquery("Adjust Variance , Are you Sure? ") Then
        WNFormExitStatus = "Canit"
      End iF
    End IF
    If WNFormExitStatus = Upper("AdjustVariance") Then
      Dim Form1 as Object
      Form1 = CreateObject("Accredo.ICUpdateVariancesForm")
      Form1.Location = Location
      Form1.TransactionDate = WNFormExitDate
      Form1.Period = PeriodForDate(Form1.TransactionDate)
      Form1.Reference = "STOCKTAKE:" & Location
      Form1.Run

      Report = CreateObject("Accredo.ICProductReport")
      Report.Layout = "Inventory Levels"
      Report.Destination = "Printer"
'      IF Company.CompanyCode = "LINKUP" OR Company.CompanyCode = "PSGLTD" then
'        Report.Printer.PrinterName = "\\LUPS-DC1\HP LJP1606DN - Inward Goods"
'      End IF
      'Report.Destination = "Screen"
      Report.Location = Location
      Report.Ignoreminimumquantity = False
      IF Bin <> "" Then
        Report.ReportFilterSort.Filter = "((BinLocation=""" & Bin & """) Or (Z_BinLocation2=""" & Bin & """)) and (ClosingPeriodToDate<>0.0)"
      Else
        Report.ReportFilterSort.Filter = "(ClosingPeriodToDate<>0.0)"
      End IF
      Report.Displayinactive = False
      Report.Preferences.IncludeRecordsWithEmptyDetail = True

      Report.Run

      Reset
      ForceClose = True
      Self.Close
      WhatNextForm = Nothing
      Exit Do
    ElseIF WNFormExitStatus = Upper("ChangeVariance") Then
      Sql = " SELECT ICQTY.LocationCode " & Chr(13) &_
            "       ,ICQTY.ProductCode " & Chr(13) &_
            "       ,ICQTY.Binlocation " & Chr(13) &_
            "       ,ICQTY.QuantityInStock " & Chr(13) &_
            "       ,ICQTY.StocktakeVariance as Variance " & Chr(13) &_
            "       ,ICQTY.QuantityAllocated " & Chr(13) &_
            "       ,ICQTY.Z_BinLocation2 as BinLocation2 " & Chr(13) &_
            "       ,(ICQTY.QuantityInStock + ICQTY.StocktakeVariance) as Quantity " & Chr(13) &_
            " FROM   ICQTY " & Chr(13) &_
            " WHERE (ICQTY.StocktakeVariance <> 0) and ICQTY.LocationCode = :Loc "
      Table = executesql(SQL, Location)
      PopulateGrids(tblStocktake, Table, tblStocktake_Clone)
      tblStocktake.Fields.Item("QuantityInStock").Visible = True
      tblStocktake.Fields.Item("Variance").Visible = True

      tblStocktake_clone.Refresh
      tblStocktake_clone.indexname = "Product"
      tblvariance.First
      Do Until tblvariance.EOF
        IF tblStocktake_clone.Findexact(tblvariance.Productcode) then
           tblStocktake_clone.Edit
           If tblvariance.SourceModule = "OE" Then tblStocktake_clone.AlloOE = tblvariance.QTY * -1
           If tblvariance.SourceModule = "IN" Then tblStocktake_clone.AlloIN = tblvariance.QTY * -1
           tblStocktake_clone.Save
        End IF
       tblvariance.Next
      Loop
      tblStocktake.refresh

      WhatNextForm = Nothing
      Exit Do
    ElseIF WNFormExitStatus = "Canit" Then
      ' Canceled ask questions Again
    Else
      Msgbox("Unknown exit Status:" & WNFormExitStatus)
    End IF
    Loop
' Reset
' ForceClose = True
' Self.Close
End IF
'TransferExitForm = Createcustomform("Barcoding\StockPurchaseOExitForm.pfd")
'  TransferExitForm.ShowModal
'  Dim ExitStatus as String
'  ExitStatus = TransferExitForm.pExitStatus
'  If ExitStatus = "Purchase" then
'    SavePurchasesOrder(True)
'    Reset
''  ElseIf ExitStatus = "Transfer" then
''    SaveTransfer(False)

'  ElseIf ExitStatus = "Close" then
'  Else
'  Error("Exit Status Unkown")
'  End IF

  eBarcode.SetFocus
End Sub

sub OnCalcCellColors(Sender as Object, Field as Object, Row as Number, Highlight as Boolean, CellFont as Object, ByRef BackColor as Number)
'IF  (User.LoginUserName <>  "JH" and User.LoginUserName <>  "SJH" and User.LoginUserName <>  "ACCREDO") Then
'  IF LEFT(tblsummary.JobGroupCode,3) = "FF-" Then CellFont.Bold = True
   IF tblStocktake.productcode = eProductCode.text Then

     BackColor = 65535 '3158271  '12701121 '13481613  '16760576
     CellFont.Bold = False
   End If
   MSGDisp = False
'End If
End Sub

Sub btbLoadPrev_Click
  DIM ICQTY as Object
  ICQTY = opentable("ICQTY")
  ICQTY.indexname = "ProductLocation"
  IF inputquery("Confirm Load Previous Count") Then
    tblStocktake.First
    Do until tblStocktake.Eof
      IF ICQTY.Findexact(tblStocktake.ProductCode, Location) Then
        tblStocktake.Edit
        tblStocktake.Quantity =  (ICQTY.QuantityInStock + ICQTY.StocktakeVariance)
        tblStocktake.Variance = ICQTY.StocktakeVariance
        tblStocktake.Save
      End IF
     tblStocktake.Next
    Loop
  End IF
End Sub


Sub OnEnter
  eBarcode.Text = ""
End Sub

Sub OnLeave

  IF CreditorSet and eBarcode.text = "000000000000" then
    CompleteStockTake
  ElseIF eBarcode.text <> "" then
    ProductScanCheck
  End IF
IF eBarcode.Text <> "" then eBarcode.SetFocus
End Sub



Sub Ref_Leave
  eBarcode.SetFocus
End Sub


Sub ProductCode_OnEnter

  If tblStocktake.ProductCode <> "" Then
    ProductDetails
    tblStocktake.Refresh
  End IF

End Sub]]>
